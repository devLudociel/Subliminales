rules_version = '2';

// Production-grade rules for subliminal.es Firestore
// Apply via: firebase deploy --only firestore:rules
// (or paste in Firebase console → Firestore → Rules)

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email == 'rubenjruiz1441@gmail.com' &&
        request.auth.token.email_verified == true;
    }

    function ownsByEmail(email) {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email.lower() == email.lower();
    }

    function ownsByUid(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Products: public read, admin write ───────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Collections (catalog groupings): public read, admin write ─
    match /collections/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Orders: owner-or-admin read, server-only writes ─────────
    // All order writes happen via the Stripe webhook using the Admin SDK,
    // which bypasses these rules. Client SDK MUST NOT write here.
    match /orders/{orderId} {
      allow read: if isAdmin() ||
                     ownsByEmail(resource.data.customer.email) ||
                     ownsByUid(resource.data.userUid);
      allow create, update, delete: if isAdmin();
    }

    // ── Reviews: public read approved, server-side writes only ──
    match /reviews/{reviewId} {
      allow read: if resource.data.approved == true || isAdmin();
      // Writes via /api/reviews (Admin SDK). Block client writes.
      allow write: if isAdmin();
    }

    // ── Returns: server-side writes only, owner read ────────────
    match /returns/{returnId} {
      allow read: if isAdmin() || ownsByUid(resource.data.userUid);
      allow write: if isAdmin();
    }

    // ── Coupons: validation via Admin SDK only ──────────────────
    match /coupons/{couponId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Newsletter: write via Admin SDK; admin-only read ────────
    match /newsletter/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Wishlists: per-user ─────────────────────────────────────
    match /wishlists/{uid} {
      allow read, write: if ownsByUid(uid) || isAdmin();
    }

    // ── User profiles ───────────────────────────────────────────
    match /users/{uid} {
      allow read: if ownsByUid(uid) || isAdmin();
      allow create: if ownsByUid(uid);
      allow update: if ownsByUid(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Blog: public read, admin write ──────────────────────────
    match /blog/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Default deny ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
