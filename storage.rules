rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email == 'rubenjruiz1441@gmail.com' &&
        request.auth.token.email_verified == true;
    }

    // Product images: public read, admin write only.
    // Limit upload size to 5MB and require image content-type.
    match /products/{file=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Blog images
    match /blog/{file=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
