---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registro">
  <div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-lg w-full bg-white border-2 border-dark p-8 md:p-12 shadow-hard rounded-xl transform rotate-1">

      <div class="text-center mb-10">
        <h2 class="font-marker text-4xl md:text-5xl text-dark mb-4">
          Únete al chiste
        </h2>
        <p class="font-hand text-2xl text-mid">
          Crea tu cuenta y únete al humor subliminal.
        </p>
      </div>
      <form class="space-y-6" id="register-form">
        <div class="space-y-5">
          <div>
            <label for="email" class="block font-hand text-xl text-dark mb-2 font-bold">Correo electrónico</label>
            <input id="email" name="email" type="email" required class="w-full px-6 py-4 font-hand text-xl border-2 border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" placeholder="tu@email.com">
          </div>
          <div>
            <label for="password" class="block font-hand text-xl text-dark mb-2 font-bold">Contraseña</label>
            <input id="password" name="password" type="password" required class="w-full px-6 py-4 font-hand text-xl border-2 border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" placeholder="Mínimo 6 caracteres">
          </div>
        </div>

        <div id="error-msg" class="text-pink font-hand text-xl hidden"></div>

        <div>
          <button type="submit" class="w-full bg-mint text-dark border-2 border-dark font-hand text-2xl py-4 cursor-pointer shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all rounded-lg font-bold">
            Registrarme
          </button>
        </div>

        <div class="relative flex items-center justify-center my-8">
          <span class="absolute px-4 bg-white text-mid font-hand text-xl z-10">o únete con</span>
          <div class="w-full border-t-2 border-dark/20 border-dashed"></div>
        </div>

        <div>
          <button type="button" id="google-btn" class="w-full flex items-center justify-center gap-4 py-4 border-2 border-dark bg-white hover:bg-bg transition-colors font-hand text-xl text-dark cursor-pointer shadow-hard hover:-translate-y-1 hover:shadow-hard-lg rounded-lg">
            <svg class="w-6 h-6" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Google
          </button>
        </div>
        
        <div class="text-center font-hand text-xl mt-8">
          <span class="text-mid">¿Ya tienes cuenta?</span>{' '}
          <a href="/login" class="text-pink hover:text-dark transition-colors font-bold no-underline">Inicia sesión</a>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { createUserWithEmailAndPassword, GoogleAuthProvider, signInWithPopup } from 'firebase/auth';
  import { auth } from '../lib/firebase/client';

  const form = document.getElementById('register-form');
  const googleBtn = document.getElementById('google-btn');
  const errorMsg = document.getElementById('error-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;
    
    if (errorMsg) errorMsg.classList.add('hidden');
    
    if(password.length < 6) {
      if (errorMsg) {
        errorMsg.textContent = 'La contraseña debe tener al menos 6 caracteres.';
        errorMsg.classList.remove('hidden');
      }
      return;
    }

    try {
      await createUserWithEmailAndPassword(auth, email, password);
      // Registration successful, redirect to profile
      window.location.href = '/perfil';
    } catch (error: any) {
      if (errorMsg) {
        errorMsg.textContent = 'Error al registrarse. Intenta de nuevo.';
        errorMsg.classList.remove('hidden');
      }
    }
  });

  googleBtn?.addEventListener('click', async () => {
    try {
      const provider = new GoogleAuthProvider();
      await signInWithPopup(auth, provider);
      window.location.href = '/perfil';
    } catch (error: any) {
      if (errorMsg) {
        errorMsg.textContent = 'Error al registrarse con Google.';
        errorMsg.classList.remove('hidden');
      }
    }
  });
</script>
