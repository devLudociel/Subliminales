---
import Layout from '../layouts/Layout.astro';
import CartPage from '../components/CartPage';
---

<Layout title="tu carrito — subliminal.es">

  <!-- Header -->
  <section class="surface-panel border-x-0 border-t-0">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <p class="ui-label mb-4">cart system</p>
      <h1 class="font-marker text-5xl md:text-7xl text-dark mb-4 leading-none glitch-text">
        tu carrito
      </h1>
      <p class="font-hand text-sm md:text-base text-mid uppercase tracking-[0.08em] m-0">
        revisa las señales antes de pagar
      </p>
    </div>
  </section>

  <CartPage client:load />

</Layout>
