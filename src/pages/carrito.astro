---
import Layout from '../layouts/Layout.astro';
import CartPage from '../components/CartPage';
---

<Layout title="tu carrito — subliminal.es">

  <!-- Header -->
  <section style="background:#4cc9a0; border-bottom:2px solid #111; padding:16px 20px;">
    <h1 style="font-family:'Permanent Marker',cursive; font-size:26px; color:#111; margin:0 0 4px;">
      tu carrito 🛒
    </h1>
    <p style="font-family:'Caveat',cursive; font-size:14px; color:#555; margin:0;">
      revisa lo que quieres antes de pagar
    </p>
  </section>

  <CartPage client:load />

</Layout>
