---
import Layout from '../layouts/Layout.astro';
import CartPage from '../components/CartPage';
---

<Layout title="tu carrito — subliminal.es">

  <!-- Header -->
  <section class="bg-mint border-b-2 border-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <h1 class="font-marker text-5xl md:text-7xl text-dark mb-4 leading-none">
        tu carrito 🛒
      </h1>
      <p class="font-hand text-2xl md:text-3xl text-dark/80 m-0">
        revisa lo que quieres antes de pagar
      </p>
    </div>
  </section>

  <CartPage client:load />

</Layout>
