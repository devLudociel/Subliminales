---
import Layout from '../../layouts/Layout.astro';
import { getBlogPostBySlug, getRecentBlogPosts, type BlogPost } from '../../lib/firebase/blog';

const { slug } = Astro.params;
let post: BlogPost | null = null;
let related: BlogPost[] = [];

try {
  post = await getBlogPostBySlug(slug as string);
  if (!post) return Astro.redirect('/blog');
  related = (await getRecentBlogPosts(4)).filter(p => p.id !== post!.id).slice(0, 3);
} catch {
  return Astro.redirect('/blog');
}

function formatDate(ts: any): string {
  if (!ts) return '';
  const d = ts.toDate ? ts.toDate() : new Date(ts);
  return d.toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' });
}
---

<Layout
  title={post.title}
  description={post.excerpt}
  image={post.image}
>
  <!-- Breadcrumb -->
  <nav class="bg-white border-b-2 border-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <span class="font-hand text-xl text-mid">
        <a href="/" class="text-mid no-underline hover:text-dark">inicio</a>
        {' → '}
        <a href="/blog" class="text-mid no-underline hover:text-dark">blog</a>
        {' → '}
        <span class="text-dark font-bold">{post.title}</span>
      </span>
    </div>
  </nav>

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-6">
      {(post.tags ?? []).map(tag => (
        <span class="tag tag-pink text-base px-3 py-1">{tag}</span>
      ))}
    </div>

    <!-- Title -->
    <h1 class="font-marker text-4xl md:text-6xl text-dark leading-tight mb-4">
      {post.title}
    </h1>

    <!-- Date -->
    <p class="font-hand text-xl text-mid mb-8">{formatDate(post.publishedAt)}</p>

    <!-- Hero image -->
    {post.image && (
      <div class="w-full aspect-video mb-10 border-2 border-dark shadow-hard rounded-xl overflow-hidden -rotate-1">
        <img src={post.image} alt={post.title} class="w-full h-full object-cover" />
      </div>
    )}

    <!-- Content — rendered as HTML from Firestore -->
    <div
      class="prose prose-lg max-w-none font-hand text-xl text-dark leading-relaxed space-y-6
        [&_h2]:font-marker [&_h2]:text-3xl [&_h2]:text-dark [&_h2]:mt-10 [&_h2]:mb-4
        [&_h3]:font-marker [&_h3]:text-2xl [&_h3]:text-dark [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:font-hand [&_p]:text-xl [&_p]:text-mid [&_p]:leading-relaxed
        [&_a]:text-pink [&_a]:no-underline [&_a:hover]:underline
        [&_strong]:text-dark [&_strong]:font-bold
        [&_ul]:list-disc [&_ul]:pl-6 [&_li]:font-hand [&_li]:text-xl [&_li]:text-mid"
      set:html={post.content}
    />

  </article>

  <!-- Related posts -->
  {related.length > 0 && (
    <section class="bg-white border-t-2 border-dark">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
        <h2 class="font-marker text-4xl text-dark mb-8">más artículos</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {related.map(p => (
            <a href={`/blog/${p.slug}`} class="no-underline block border-2 border-dark bg-white shadow-hard hover:-translate-y-1 transition-all rounded-xl overflow-hidden">
              {p.image ? (
                <div class="aspect-video overflow-hidden">
                  <img src={p.image} alt={p.title} class="w-full h-full object-cover" />
                </div>
              ) : (
                <div class="aspect-video bg-mint/20 flex items-center justify-center">
                  <span class="text-4xl">✍️</span>
                </div>
              )}
              <div class="p-4">
                <h3 class="font-marker text-xl text-dark mb-1 leading-tight">{p.title}</h3>
                <p class="font-hand text-base text-mid line-clamp-2">{p.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-pink border-t-2 border-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16 text-center">
      <h2 class="font-marker text-3xl md:text-5xl text-white mb-4">¿te gustó? pues mira la tienda</h2>
      <a href="/tienda" class="inline-block bg-dark text-mint border-2 border-dark font-hand text-xl px-10 py-4 no-underline shadow-hard hover:-translate-y-1 transition-all rounded-lg">
        ver tienda →
      </a>
    </div>
  </section>

</Layout>
