---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { products, categories, getProductsByCategory } from '../data/products';

const selectedCat = Astro.url.searchParams.get('cat') || 'all';
const filteredProducts = getProductsByCategory(selectedCat);

const rotations = ['rotate(-1.5deg)', 'rotate(1deg)', 'rotate(-0.5deg)', 'rotate(1.5deg)', 'rotate(-1deg)', 'rotate(0.8deg)'];

const catLabels: Record<string, string> = {
  all:        '📦 todo',
  camisetas:  '👕 camisetas',
  sudaderas:  '🧥 sudaderas',
  tazas:      '☕ tazas',
  termos:     '🧃 termos',
  posters:    '🖼️ posters',
  accesorios: '🎁 accesorios',
};
---

<Layout title="la tienda — subliminal.es" description="Todos los productos con mensajes de humor y doble sentido.">

  <!-- Header -->
  <section style="background:#4cc9a0; border-bottom:2px solid #111; padding:16px 20px;">
    <div style="display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:10px;">
      <div>
        <h1 style="font-family:'Permanent Marker',cursive; font-size:28px; color:#111; margin:0 0 4px;">
          la tienda
        </h1>
        <p style="font-family:'Caveat',cursive; font-size:14px; color:#555; margin:0;">
          {filteredProducts.length} productos{selectedCat !== 'all' ? ` en ${catLabels[selectedCat] ?? selectedCat}` : ''}
        </p>
      </div>
      <div style="display:flex; gap:8px;">
        <button style="font-family:'Caveat',cursive; font-size:12px; padding:5px 12px; border:1.5px solid #111; background:#fff; color:#111; cursor:pointer;">filtrar ↓</button>
        <button style="font-family:'Caveat',cursive; font-size:12px; padding:5px 12px; border:1.5px solid #111; background:#fff; color:#111; cursor:pointer;">ordenar ↓</button>
      </div>
    </div>
  </section>

  <!-- Category filters -->
  <div style="background:#fff; border-bottom:1.5px solid #111; padding:10px 20px; display:flex; gap:8px; flex-wrap:wrap;">
    {Object.entries(catLabels).map(([id, label]) => {
      const active = selectedCat === id;
      return (
        <a
          href={id === 'all' ? '/tienda' : `/tienda?cat=${id}`}
          style={`font-family:'Caveat',cursive; font-size:13px; padding:4px 12px; border:1.5px solid #111; text-decoration:none; display:inline-block; ${active ? 'background:#f72585; color:#fff; box-shadow:2px 2px 0 #111;' : 'background:#fff; color:#111;'}`}
        >
          {label}
        </a>
      );
    })}
  </div>

  <!-- Product grid -->
  <div style="padding:16px 20px;">
    {filteredProducts.length > 0 ? (
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(155px,1fr)); gap:14px;">
        {filteredProducts.map((product, i) => (
          <ProductCard product={product} rotation={rotations[i % rotations.length]} />
        ))}
      </div>
    ) : (
      <div style="text-align:center; padding:60px 20px;">
        <p style="font-size:48px; margin:0 0 8px;">🔍</p>
        <h3 style="font-family:'Permanent Marker',cursive; font-size:20px; color:#111; margin:0 0 8px;">sin resultados</h3>
        <p style="font-family:'Caveat',cursive; font-size:14px; color:#666; margin:0 0 16px;">No hay productos en esta categoría todavía.</p>
        <a href="/tienda" class="btn-primary">ver todo</a>
      </div>
    )}
  </div>

</Layout>
