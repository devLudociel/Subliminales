---
import AdminLayout from '../../layouts/AdminLayout.astro';
import ShippingConfig from '../../components/admin/ShippingConfig';
---

<AdminLayout title="Configuración">
  <div class="px-4 md:px-0">
    <div class="mb-10">
      <h1 class="font-marker text-5xl md:text-6xl text-dark mb-4 leading-none">Configuración</h1>
      <p class="font-hand text-2xl text-mid">Precios y métodos de envío.</p>
    </div>
    <ShippingConfig client:load />
  </div>
</AdminLayout>
