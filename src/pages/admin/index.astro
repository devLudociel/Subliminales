---
import AdminLayout from '../../layouts/AdminLayout.astro';
import ProductList from '../../components/admin/ProductList';
---

<AdminLayout title="Productos">
  <div class="px-4 md:px-0">
    <div class="mb-10">
      <h1 class="font-marker text-5xl md:text-6xl text-dark mb-4 leading-none">Productos</h1>
      <p class="font-hand text-2xl text-mid">Gestiona tu catálogo de productos con chiste.</p>
    </div>
    <ProductList client:load />
  </div>
</AdminLayout>
