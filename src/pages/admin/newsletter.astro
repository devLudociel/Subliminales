---
import AdminLayout from '../../layouts/AdminLayout.astro';
import NewsletterManager from '../../components/admin/NewsletterManager';
---

<AdminLayout title="Newsletter">
  <div class="px-4 md:px-0">
    <div class="mb-10">
      <h1 class="font-marker text-5xl md:text-6xl text-dark mb-4 leading-none">Newsletter</h1>
      <p class="font-hand text-2xl text-mid">Suscriptores de la lista de correo.</p>
    </div>
    <NewsletterManager client:load />
  </div>
</AdminLayout>
