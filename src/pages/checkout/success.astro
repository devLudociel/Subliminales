---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="¡Pedido Confirmado! — subliminal.es">

  <section class="bg-mint border-b-2 border-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <h1 class="font-marker text-5xl md:text-6xl text-dark leading-none">¡Pedido Confirmado! 🎉</h1>
    </div>
  </section>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 text-center">
    <div class="text-8xl mb-6 animate-bounce">✅</div>

    <h2 class="font-marker text-4xl md:text-5xl text-dark mb-4">
      ¡Gracias por tu compra!
    </h2>
    <p class="font-hand text-2xl md:text-3xl text-mid mb-4 leading-relaxed">
      Te hemos enviado un email de confirmación con los detalles del pedido.
    </p>
    <p class="font-hand text-xl text-mid mb-10">
      Tu pedido se procesará en 24/48h. Si tienes dudas escríbenos.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/tienda"
        class="bg-pink text-white border-2 border-dark font-hand text-2xl px-10 py-4 no-underline inline-block shadow-hard hover:-translate-y-1 transition-all rounded-lg">
        seguir comprando →
      </a>
      <a href="/"
        class="bg-white text-dark border-2 border-dark font-hand text-2xl px-10 py-4 no-underline inline-block shadow-hard hover:-translate-y-1 transition-all rounded-lg">
        volver al inicio
      </a>
    </div>
  </div>

</Layout>

<script>
  // Clear cart after successful payment
  import { clearCart } from '../../store/cart';
  clearCart();
</script>
