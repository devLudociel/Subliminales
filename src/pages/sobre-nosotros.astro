---
import Layout from '../layouts/Layout.astro';
---

<Layout title="sobre nosotros — subliminal.es">

  <!-- Hero dark -->
  <section class="relative overflow-hidden border-b border-dark">
    <img src="/brand/5.png" alt="Hidden Message visual" class="absolute inset-0 w-full h-full object-cover opacity-45" />
    <div class="absolute inset-0 bg-gradient-to-r from-bg via-bg/80 to-black/30"></div>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 relative z-10 text-center md:text-left">
      <p class="ui-label mb-5">manifesto / visual mind lab</p>
      <h1 class="font-marker text-5xl md:text-7xl lg:text-8xl text-dark mb-6 leading-none glitch-text">
        somos subliminal
      </h1>
      <p class="font-hand text-sm md:text-lg text-mid uppercase tracking-[0.08em] m-0 max-w-2xl leading-relaxed mx-auto md:mx-0">
        Un laboratorio visual streetwear: diseño gráfico, impresión, cultura internet, glitch, humor absurdo y mensajes ocultos.
      </p>
    </div>
  </section>

  <!-- Cómo empezó -->
  <section class="bg-bg border-b border-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <p class="ui-label mb-4 text-center md:text-left">adn de marca</p>
      <h2 class="font-marker text-4xl md:text-5xl text-dark mb-10 text-center md:text-left">
        no es una tienda normal
      </h2>
      <div class="flex flex-col md:flex-row gap-8 md:gap-16 items-center md:items-start">
        <div class="surface-panel w-32 h-40 md:w-48 md:h-56 shrink-0 shadow-hard">
          <img src="/brand/1.png" alt="Subliminal Signal" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="flex-1 text-center md:text-left">
          <p class="font-hand text-sm md:text-base text-mid uppercase tracking-[0.08em] leading-relaxed mb-6">
            Subliminal.es mezcla streetwear, diseño gráfico, impresión, graffiti, posters underground, stickers urbanos y estética cyberpunk.
          </p>
          <p class="font-hand text-sm md:text-base text-mid uppercase tracking-[0.08em] leading-relaxed m-0">
            La idea es simple: crear diseños absurdamente memorables. Piezas con impacto visual real, humor inteligente y una identidad que se reconoce al instante.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cómo trabajamos -->
  <section class="surface-panel border-x-0 border-b border-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <h2 class="font-marker text-4xl md:text-5xl text-dark mb-12 text-center">
        reglas del laboratorio
      </h2>
      <div class="flex flex-col gap-6 md:gap-8">
        {[
          { code: '01', title: 'negro dominante', desc: 'Base oscura, contraste fuerte y neón controlado. Nunca pastel suave.' },
          { code: '02', title: 'caos controlado',  desc: 'Glitch, CMYK offset, warning labels, barcodes y texturas sin caer en amateur.' },
          { code: '03', title: 'espalda gigante',  desc: 'Frente limpio. Espalda con composición visual extrema y sticker style.' },
          { code: '04', title: 'ideas pegajosas', desc: 'Si no se recuerda, no entra al drop.' },
        ].map((item, i) => (
          <div class="flex flex-col md:flex-row gap-6 md:gap-8 items-start p-6 md:p-8 bg-white border border-dark shadow-hard hover:-translate-y-1 transition-all duration-300">
            <span class="font-marker text-4xl md:text-5xl text-pink shrink-0">{item.code}</span>
            <div>
              <p class="font-marker text-2xl md:text-3xl font-bold text-dark mb-3">{item.title}</p>
              <p class="font-hand text-sm md:text-base text-mid uppercase tracking-[0.08em] m-0 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ¿Hablamos? -->
  <section class="bg-pink border-b border-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 text-center">
      <h2 class="font-marker text-4xl md:text-5xl text-white mb-6">
        visual signal detected
      </h2>
      <p class="font-hand text-sm md:text-base text-white/85 uppercase tracking-[0.08em] mb-10 leading-relaxed">
        Colaboraciones, ideas raras, drops y proyectos gráficos.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href="/contacto" class="bg-dark text-mint border border-dark font-hand text-xs uppercase tracking-[0.14em] px-10 py-4 no-underline shadow-hard hover:-translate-y-1 transition-all">
          contacto
        </a>
        <a href="/tienda" class="bg-white text-dark border border-dark font-hand text-xs uppercase tracking-[0.14em] px-10 py-4 no-underline shadow-hard hover:-translate-y-1 transition-all">
          ver drop
        </a>
      </div>
    </div>
  </section>

</Layout>
