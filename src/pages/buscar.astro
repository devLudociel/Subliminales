---
import Layout from '../layouts/Layout.astro';
import SearchResults from '../components/SearchResults';

const q = Astro.url.searchParams.get('q') ?? '';
---

<Layout
  title={q ? `Búsqueda: ${q}` : 'Buscar productos'}
  description="Busca camisetas, sudaderas, tazas y más en Subliminal.es"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <h1 class="font-marker text-4xl md:text-5xl text-dark mb-8">buscar</h1>
    <SearchResults client:load />
  </div>
</Layout>
