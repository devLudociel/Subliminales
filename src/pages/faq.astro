---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: '¿Cómo son las tallas?',
    a: 'Nuestras camisetas y sudaderas tienen un corte unisex ligeramente oversize. Si prefieres un ajuste más ceñido, te recomendamos pedir una talla menos de la que usas habitualmente.',
  },
  {
    q: '¿Cuánto tiempo tarda el envío?',
    a: 'Los envíos a la Península tardan entre 24 y 48 horas laborables una vez que el pedido ha sido procesado. La producción bajo demanda puede sumar de 1 a 3 días extra.',
  },
  {
    q: '¿Los chistes son originales?',
    a: 'Completamente. Cada diseño sale de nuestra cabeza. Si alguna vez ves una copia por ahí, diles que el original es nuestro y mándanos un MD para quejarnos juntos.',
  },
  {
    q: '¿Cómo debo lavar las prendas?',
    a: 'Lava siempre del revés con agua fría (máx 30º). No uses secadora ni planches directamente sobre el diseño. Trata la prenda como si fuera tu chiste favorito, con cariño.',
  },
  {
    q: '¿Aceptan devoluciones?',
    a: 'Sí, tienes 30 días para devolver la prenda si no te convence, siempre y cuando no la hayas usado ni lavado (póntela para probar, pero no te vayas de fiesta con ella).',
  },
  {
    q: '¿Hacen envíos internacionales?',
    a: 'De momento solo enviamos a toda España, pero estamos trabajando para llevar nuestros chistes a más países pronto.',
  },
];
---

<Layout title="Preguntas Frecuentes — subliminal.es" description="Respuestas a las preguntas más comunes sobre nuestra tienda y productos.">
  <section class="bg-mint border-b-2 border-dark py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-marker text-5xl md:text-7xl text-dark mb-6 leading-none">Preguntas Frecuentes</h1>
      <p class="font-hand text-2xl md:text-3xl text-dark/80 max-w-2xl mx-auto">Lo que todo el mundo nos pregunta antes de comprar. Léelo antes de mandarnos un email, porfa.</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 space-y-6">
    {faqs.map((faq, i) => (
      <details class="bg-white border-2 border-dark shadow-hard group rounded-xl overflow-hidden cursor-pointer open:bg-light-pink transition-colors">
        <summary class="flex items-center justify-between p-6 md:p-8 list-none outline-none">
          <h3 class="font-marker text-2xl md:text-3xl text-dark pr-6">{faq.q}</h3>
          <span class="text-4xl text-pink shrink-0 group-open:rotate-45 transition-transform duration-300">+</span>
        </summary>
        <div class="px-6 md:px-8 pb-6 md:pb-8 border-t-2 border-dark/10 pt-4 md:pt-6">
          <p class="font-hand text-xl md:text-2xl text-mid leading-relaxed">{faq.a}</p>
        </div>
      </details>
    ))}

    <div class="text-center pt-12 md:pt-16">
      <p class="font-hand text-3xl text-dark mb-8">¿Tienes una pregunta más rara?</p>
      <a href="/contacto" class="btn-dark text-2xl px-10 py-4 shadow-hard hover:-translate-y-1 transition-all inline-block rounded-lg">Escríbenos</a>
    </div>
  </div>
</Layout>
