---
import Layout from '../layouts/Layout.astro';
import CheckoutForm from '../components/CheckoutForm';
---

<Layout title="Finalizar Compra — subliminal.es">

  <section class="bg-mint border-b-2 border-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <h1 class="font-marker text-5xl md:text-6xl text-dark leading-none mb-2">Finalizar Compra</h1>
      <p class="font-hand text-2xl text-dark/70 m-0">casi casi... 🎉</p>
    </div>
  </section>

  <CheckoutForm client:load />

</Layout>
