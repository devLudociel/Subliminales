---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Checkout — Finalizar Compra">
  <section class="bg-mint border-b-2 border-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <h1 class="font-marker text-5xl md:text-6xl text-dark leading-none">Finalizar Compra</h1>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
      <!-- Form -->
      <div class="lg:col-span-3 space-y-8">
        <!-- Contact -->
        <div class="bg-white border-2 border-dark p-6 md:p-10 shadow-hard rounded-xl">
          <h2 class="font-marker text-3xl text-dark mb-6">Información de Contacto</h2>
          <div class="space-y-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block font-hand text-xl text-dark mb-2 font-bold">Nombre</label>
                <input type="text" placeholder="Juan" class="w-full px-5 py-4 font-hand text-xl border-2 border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" />
              </div>
              <div>
                <label class="block font-hand text-xl text-dark mb-2 font-bold">Apellidos</label>
                <input type="text" placeholder="García" class="w-full px-5 py-4 font-hand text-xl border-2 border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" />
              </div>
            </div>
            <div>
              <label class="block font-hand text-xl text-dark mb-2 font-bold">Email</label>
              <input type="email" placeholder="juan@email.com" class="w-full px-5 py-4 font-hand text-xl border-2 border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" />
              <p class="font-hand text-lg text-mid mt-2">Aquí te enviaremos la confirmación del pedido</p>
            </div>
          </div>
        </div>

        <!-- Shipping Address -->
        <div class="bg-white border-2 border-dark p-6 md:p-10 shadow-hard rounded-xl">
          <h2 class="font-marker text-3xl text-dark mb-6">Dirección de Envío</h2>
          <div class="space-y-5">
            <div>
              <label class="block font-hand text-xl text-dark mb-2 font-bold">Dirección</label>
              <input type="text" placeholder="Calle Ejemplo 123, Piso 2" class="w-full px-5 py-4 font-hand text-xl border-2 border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block font-hand text-xl text-dark mb-2 font-bold">Ciudad</label>
                <input type="text" placeholder="Madrid" class="w-full px-5 py-4 font-hand text-xl border-2 border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" />
              </div>
              <div>
                <label class="block font-hand text-xl text-dark mb-2 font-bold">Código Postal</label>
                <input type="text" placeholder="28001" class="w-full px-5 py-4 font-hand text-xl border-2 border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" />
              </div>
            </div>
          </div>
        </div>

        <!-- Payment -->
        <div class="bg-white border-2 border-dark p-6 md:p-10 shadow-hard rounded-xl">
          <h2 class="font-marker text-3xl text-dark mb-6">Método de Pago</h2>
          <div class="space-y-4">
            {[
              { id: 'card', label: 'Tarjeta de crédito/débito', icon: '💳' },
              { id: 'paypal', label: 'PayPal', icon: '🅿️' },
              { id: 'bizum', label: 'Bizum', icon: '📱' },
            ].map((method, i) => (
              <label class={`flex items-center gap-5 p-5 border-2 border-dark cursor-pointer transition-all rounded-xl ${i === 0 ? 'bg-pink/10 shadow-hard' : 'bg-white hover:bg-bg'}`}>
                <input type="radio" name="payment" value={method.id} checked={i === 0} class="w-5 h-5 accent-pink" />
                <span class="text-3xl">{method.icon}</span>
                <span class="font-hand text-xl md:text-2xl text-dark font-bold">{method.label}</span>
              </label>
            ))}
          </div>

          <!-- Stripe default -->
          <div class="mt-6 space-y-4" id="stripe-form">
            <div class="p-6 md:p-8 border-2 border-dark bg-mint-light text-center rounded-xl">
              <span class="text-5xl mb-4 block">🔒</span>
              <h3 class="font-marker text-2xl text-dark mb-3">Pago Encriptado con Stripe</h3>
              <p class="font-hand text-xl text-mid">Al confirmar el pedido, serás redirigido de forma segura a la pasarela de Stripe para procesar tu tarjeta.</p>
            </div>
          </div>
        </div>

        <!-- Submit -->
        <button class="w-full bg-dark text-mint border-2 border-dark font-hand text-3xl py-5 cursor-pointer shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all rounded-lg flex items-center justify-center gap-3">
          🔒 Pagar de forma segura
        </button>

        <p class="text-center font-hand text-lg text-mid">
          Pago 100% seguro con encriptación SSL. Tu información está protegida.
        </p>
      </div>

      <!-- Order summary -->
      <div class="lg:col-span-2">
        <div class="bg-white border-2 border-dark p-6 md:p-8 shadow-hard sticky top-24 rounded-xl">
          <h2 class="font-marker text-3xl text-dark mb-6">Resumen del pedido</h2>
          <div id="cart-summary" class="space-y-4 mb-6">
            <p class="font-hand text-xl text-mid text-center py-4">Cargando carrito...</p>
          </div>
          <div class="border-t-2 border-dark pt-4 space-y-3">
            <div class="flex justify-between font-hand text-xl">
              <span class="text-mid">Subtotal</span>
              <span id="subtotal" class="text-dark font-bold">—</span>
            </div>
            <div class="flex justify-between font-hand text-xl">
              <span class="text-mid">IVA (21%)</span>
              <span id="tax" class="text-dark font-bold">—</span>
            </div>
            <div class="flex justify-between font-marker text-3xl pt-3 border-t-2 border-dark">
              <span class="text-dark">Total</span>
              <span id="total" class="text-pink">—</span>
            </div>
          </div>

          <!-- Trust badges -->
          <div class="mt-8 pt-4 border-t-2 border-dark/20">
            <div class="flex flex-wrap gap-4 justify-center">
              <span class="font-hand text-lg text-mid flex items-center gap-2">📦 Envío en 24/48h</span>
              <span class="font-hand text-lg text-mid flex items-center gap-2">✅ Garantía 30 días</span>
              <span class="font-hand text-lg text-mid flex items-center gap-2">🔒 Pago seguro</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { cartItems, cartTotal } from '../store/cart';

  function updateSummary() {
    const items = cartItems.get();
    const total = cartTotal.get();
    const tax = total * 0.21;
    const subtotal = total;

    const summaryEl = document.getElementById('cart-summary');
    const subtotalEl = document.getElementById('subtotal');
    const taxEl = document.getElementById('tax');
    const totalEl = document.getElementById('total');

    if (summaryEl) {
      if (items.length === 0) {
        summaryEl.innerHTML = '<p class="font-hand text-xl text-mid text-center py-4">Tu carrito está vacío</p>';
      } else {
        summaryEl.innerHTML = items.map(item => `
          <div class="flex items-center gap-4 p-3 bg-bg rounded-lg border border-dark/10">
            <div class="w-12 h-12 rounded-lg bg-mint-light border border-dark flex items-center justify-center shrink-0 text-2xl">📦</div>
            <div class="flex-1 min-w-0">
              <p class="font-hand text-xl text-dark font-bold truncate">${item.name}</p>
              <p class="font-hand text-lg text-mid">×${item.quantity}</p>
            </div>
            <span class="font-hand text-xl font-bold text-dark">${(item.price * item.quantity).toFixed(2)}€</span>
          </div>
        `).join('');
      }
    }

    if (subtotalEl) subtotalEl.textContent = `${subtotal.toFixed(2)}€`;
    if (taxEl) taxEl.textContent = `${tax.toFixed(2)}€`;
    if (totalEl) totalEl.textContent = `${(subtotal + tax).toFixed(2)}€`;
  }

  cartItems.subscribe(updateSummary);
  updateSummary();
</script>
