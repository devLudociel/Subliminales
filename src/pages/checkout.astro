---
import Layout from '../layouts/Layout.astro';
import CheckoutForm from '../components/CheckoutForm';
---

<Layout title="Finalizar Compra — subliminal.es">

  <section class="surface-panel border-x-0 border-t-0">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16">
      <p class="ui-label mb-4">checkout protocol</p>
      <h1 class="font-marker text-5xl md:text-6xl text-dark leading-none mb-2 glitch-text">Finalizar Compra</h1>
      <p class="font-hand text-sm md:text-base text-mid uppercase tracking-[0.08em] m-0">último paso antes de activar el envío.</p>
    </div>
  </section>

  <CheckoutForm client:load />

</Layout>
