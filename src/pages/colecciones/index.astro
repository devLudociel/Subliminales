---
import Layout from '../../layouts/Layout.astro';
import { products } from '../../data/products';

const colecciones = [
  {
    id: 'patochar',
    name: 'PATOCHAR',
    desc: 'Cuando el clima es un chiste (y no solo el tiempo). Diseños que mezclan lo cotidiano con el absurdo.',
    color: '#f72585',
    textColor: '#fff',
    items: products.filter(p => p.collection === 'mind-control' || p.collection === 'hidden-truth').slice(0, 4),
  },
  {
    id: 'hidden-truth',
    name: 'HIDDEN TRUTH',
    desc: 'La verdad siempre estuvo ahí. Mira otra vez.',
    color: '#111',
    textColor: '#fff',
    items: products.filter(p => p.collection === 'hidden-truth').slice(0, 4),
  },
  {
    id: 'wake-up',
    name: 'WAKE UP',
    desc: 'Abre los ojos. En serio.',
    color: '#4cc9a0',
    textColor: '#111',
    items: products.filter(p => p.collection === 'wake-up').slice(0, 4),
  },
  {
    id: 'dual-meaning',
    name: 'DUAL MEANING',
    desc: 'Dos lecturas, un solo diseño. Lo que ves no es lo único que hay.',
    color: '#fde8f0',
    textColor: '#111',
    items: products.filter(p => p.collection === 'dual-meaning').slice(0, 4),
  },
];

const categoryEmoji: Record<string, string> = {
  camisetas: '👕', sudaderas: '🧥', tazas: '☕',
  termos: '🧃', posters: '🖼️', accesorios: '🎁',
};
---

<Layout title="colecciones — subliminal.es">

  <!-- Header -->
  <section style="background:#f72585; border-bottom:2px solid #111; padding:20px;">
    <h1 style="font-family:'Permanent Marker',cursive; font-size:32px; color:#fff; margin:0 0 6px;">
      colecciones
    </h1>
    <p style="font-family:'Caveat',cursive; font-size:15px; color:rgba(255,255,255,0.85); margin:0;">
      cada colección es un universo con su propio chiste
    </p>
  </section>

  <!-- Collections list -->
  <div style="padding:20px; display:flex; flex-direction:column; gap:16px; max-width:860px; margin:0 auto;">
    {colecciones.map(col => (
      <div style="display:flex; border:1.5px solid #111; overflow:hidden; background:#fff;">

        <!-- Left zone: color band with rotated name -->
        <div style={`background:${col.color}; color:${col.textColor}; width:70px; min-width:70px; display:flex; align-items:center; justify-content:center; flex-shrink:0;`}>
          <span style={`font-family:'Permanent Marker',cursive; font-size:12px; writing-mode:vertical-rl; transform:rotate(180deg); letter-spacing:2px;`}>
            {col.name}
          </span>
        </div>

        <!-- Right zone -->
        <div style="flex:1; padding:14px; border-left:2px solid #111;">
          <h2 style="font-family:'Permanent Marker',cursive; font-size:20px; color:#111; margin:0 0 6px;">
            {col.name}
          </h2>
          <p style="font-family:'Caveat',cursive; font-size:14px; color:#666; line-height:1.4; margin:0 0 12px;">
            {col.desc}
          </p>

          <!-- Mini product grid -->
          <div style="display:flex; gap:8px; margin-bottom:12px; flex-wrap:wrap;">
            {col.items.length > 0 ? col.items.slice(0, 3).map(p => (
              <a href={`/producto/${p.slug}`} style="text-decoration:none;">
                <div class="img-placeholder" style="width:65px; height:65px; border:1.5px solid #111; flex-shrink:0;">
                  <span style="font-size:22px;">{categoryEmoji[p.category] ?? '📦'}</span>
                </div>
              </a>
            )) : (
              <span style="font-family:'Caveat',cursive; font-size:13px; color:#999;">próximamente...</span>
            )}
            {col.items.length > 3 && (
              <div style="width:65px; height:65px; border:1.5px solid #111; background:#fde8f0; display:flex; align-items:center; justify-content:center; font-family:'Caveat',cursive; font-size:12px; color:#666; flex-shrink:0;">
                +{col.items.length - 3} más
              </div>
            )}
          </div>

          <a
            href={`/tienda`}
            style={`background:${col.color}; color:${col.textColor}; border:1.5px solid #111; font-family:'Caveat',cursive; font-size:13px; padding:5px 14px; text-decoration:none; display:inline-block;`}
          >
            ver colección →
          </a>
        </div>
      </div>
    ))}
  </div>

</Layout>
