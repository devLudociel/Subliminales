---
import Layout from '../../layouts/Layout.astro';
import { getAllCollections, type Collection } from '../../lib/firebase/admin-collections';
import { getAllProducts } from '../../data/products';

let firestoreCollections: Collection[] = [];
try {
  firestoreCollections = await getAllCollections();
} catch {}

const allProducts = await getAllProducts();

// Fallback static config if Firestore empty
const STATIC = [
  { slug: 'mind-control',  name: 'MIND CONTROL', desc: 'Quién controla lo que piensas. Diseños que te hacen pensar dos veces.', bg: '#f72585', light: false },
  { slug: 'hidden-truth',  name: 'HIDDEN TRUTH',  desc: 'La verdad siempre estuvo ahí. Mira otra vez.',                        bg: '#111111', light: false },
  { slug: 'wake-up',       name: 'WAKE UP',       desc: 'Abre los ojos. En serio.',                                            bg: '#4cc9a0', light: true  },
  { slug: 'dual-meaning',  name: 'DUAL MEANING',  desc: 'Dos lecturas, un solo diseño. Lo que ves no es lo único que hay.',   bg: '#fef0f4', light: true  },
];

const colecciones = firestoreCollections.length > 0
  ? firestoreCollections.map(c => ({
      slug: c.slug,
      name: c.name,
      desc: c.desc,
      bg: c.color ?? '#f72585',
      light: false,
    }))
  : STATIC;

const categoryEmoji: Record<string, string> = {
  camisetas: '👕', sudaderas: '🧥', tazas: '☕',
  termos: '🧃', posters: '🖼️', accesorios: '🎁',
};
---

<Layout title="Colecciones" description="Explora nuestras colecciones temáticas de ropa con chiste.">

  <!-- Header -->
  <section class="bg-pink border-b-2 border-dark py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-marker text-5xl md:text-7xl text-white mb-6 leading-none">colecciones</h1>
      <p class="font-hand text-2xl md:text-3xl text-white/90 m-0 max-w-2xl mx-auto">
        cada colección es un universo con su propio chiste. elige tu veneno.
      </p>
    </div>
  </section>

  <!-- Collections list -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 space-y-12">
    {colecciones.map((col, i) => {
      const colProducts = allProducts
        .filter(p => p.collection === col.slug)
        .slice(0, 4);
      const textColor = col.light ? '#111' : '#fff';
      const borderColor = col.light ? '#111' : 'rgba(255,255,255,0.5)';
      return (
        <div
          class={`flex flex-col sm:flex-row border-2 border-dark overflow-hidden bg-white shadow-hard transform ${i % 2 === 0 ? '-rotate-1' : 'rotate-1'} hover:rotate-0 transition-transform rounded-xl`}
        >
          <!-- Color band -->
          <div
            class="w-full sm:w-24 sm:min-w-[96px] py-4 sm:py-0 flex items-center justify-center shrink-0 border-b-2 sm:border-b-0 sm:border-r-2 border-dark"
            style={`background:${col.bg}; color:${textColor};`}
          >
            <span class="font-marker text-3xl sm:text-4xl sm:[writing-mode:vertical-rl] sm:rotate-180 tracking-widest text-center">
              {col.name}
            </span>
          </div>

          <!-- Content -->
          <div class="flex-1 p-6 md:p-10">
            <h2 class="font-marker text-3xl md:text-4xl text-dark mb-4">{col.name}</h2>
            <p class="font-hand text-xl md:text-2xl text-mid leading-relaxed mb-8 max-w-xl">{col.desc}</p>

            <!-- Mini product grid -->
            <div class="flex gap-4 mb-8 flex-wrap">
              {colProducts.length > 0 ? colProducts.slice(0, 3).map(p => (
                <a href={`/producto/${p.slug}`} class="no-underline hover:-translate-y-1 transition-transform">
                  <div class="w-20 h-24 md:w-24 md:h-32 border-2 border-dark bg-bg flex items-center justify-center shadow-hard rounded-lg overflow-hidden">
                    {p.image
                      ? <img src={p.image} alt={p.name} class="w-full h-full object-cover" />
                      : <span class="text-4xl md:text-5xl">{categoryEmoji[p.category] ?? '📦'}</span>
                    }
                  </div>
                </a>
              )) : (
                <span class="font-hand text-2xl text-mid opacity-75">próximamente...</span>
              )}
              {colProducts.length > 3 && (
                <div class="w-20 h-24 md:w-24 md:h-32 border-2 border-dark bg-mint-light flex items-center justify-center font-hand text-2xl md:text-3xl text-dark shrink-0 shadow-hard rounded-lg">
                  +{colProducts.length - 3}
                </div>
              )}
            </div>

            <a
              href={`/tienda?col=${col.slug}`}
              class="border-2 border-dark font-hand text-2xl px-8 py-3 no-underline inline-block shadow-hard hover:-translate-y-1 transition-transform rounded-lg"
              style={`background:${col.bg}; color:${textColor};`}
            >
              ver colección →
            </a>
          </div>
        </div>
      );
    })}
  </div>
</Layout>
