---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getFeaturedProducts, collections as staticCollections } from '../data/products';
import { getAllCollections } from '../lib/firebase/admin-collections';

let firestoreCollections: Array<{ slug: string; name: string; desc: string; color?: string }> = [];
try {
  firestoreCollections = await getAllCollections();
} catch {}

const displayCollections = firestoreCollections.length > 0
  ? firestoreCollections.slice(0, 3).map((c, i) => ({
      id: c.slug,
      name: c.name.toUpperCase(),
      desc: c.desc,
      color: c.color ?? ['#FF008C', '#00D9FF', '#FFE600'][i % 3],
      image: [`/brand/6.png`, `/brand/2.png`, `/brand/4.png`][i % 3],
    }))
  : [
      { id: 'drunk-thoughts', name: 'DRUNK THOUGHTS', desc: 'humor visual + cerveza + graffiti', color: '#FF008C', image: '/brand/6.png' },
      { id: 'visual-noise',   name: 'VISUAL NOISE',   desc: 'sobrecarga mental, señal perdida',  color: '#00D9FF', image: '/brand/2.png' },
      { id: 'cmyk-disorder',  name: 'CMYK DISORDER',  desc: 'el error es diseño',                color: '#FFE600', image: '/brand/4.png' },
    ];

const featured = (await getFeaturedProducts()).slice(0, 4);

const labStats = [
  ['DROP', '001'],
  ['NOISE', '99%'],
  ['MODE', 'ON'],
  ['SIGNAL', 'LIVE'],
];
---

<Layout title="Visual Mind Lab" description="Streetwear visual, glitch, humor absurdo y drops que actúan en tu mente.">

  <!-- Hero -->
  <section class="relative min-h-[78vh] border-b border-dark overflow-hidden flex items-end">
    <img src="/brand/1.png" alt="Subliminal Signal visual system" class="absolute inset-0 w-full h-full object-cover opacity-70" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/45 via-black/65 to-bg"></div>
    <div class="absolute inset-0 pointer-events-none bg-[linear-gradient(rgba(245,245,245,.06)_1px,transparent_1px),linear-gradient(90deg,rgba(245,245,245,.05)_1px,transparent_1px)] bg-[size:42px_42px]"></div>

    <div class="relative z-10 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pt-24 pb-10 md:pb-16">
      <div class="max-w-5xl">
        <div class="flex flex-wrap gap-3 mb-6">
          <span class="tag tag-pink shadow-hard">drop 001</span>
          <span class="tag tag-dark shadow-hard">visual mind lab</span>
          <span class="tag tag-mint shadow-hard">signal on</span>
        </div>
        <h1 class="font-marker text-5xl sm:text-6xl md:text-8xl lg:text-9xl text-dark leading-[.9] m-0 glitch-text">
          diseños que actúan en tu mente
        </h1>
        <p class="font-hand text-base md:text-xl text-dark/80 mt-6 mb-8 max-w-2xl uppercase tracking-[0.08em] leading-relaxed">
          Streetwear gráfico, humor absurdo, glitch, impresión y mensajes que se quedan pegados.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/tienda" class="btn-primary shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all">ver drop</a>
          <a href="/colecciones" class="btn-outline bg-bg/80 shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all">colecciones</a>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mt-12 max-w-3xl">
        {labStats.map(([label, value]) => (
          <div class="border border-dark bg-bg/70 p-3">
            <p class="font-hand text-[10px] text-mid uppercase tracking-[0.18em] mb-2">{label}</p>
            <p class="font-marker text-2xl md:text-3xl text-mint m-0 leading-none">{value}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="border-b border-dark bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex flex-col lg:flex-row gap-6 lg:items-center lg:justify-between">
      <p class="ui-label m-0">explorar sistema</p>
      <div class="flex gap-3 flex-wrap">
        <a href="/tienda?cat=camisetas" class="tag tag-pink no-underline shadow-hard">camisetas</a>
        <a href="/tienda?cat=posters" class="tag tag-mint no-underline shadow-hard">posters</a>
        <a href="/tienda?cat=accesorios" class="tag tag-light no-underline shadow-hard">stickers</a>
        <a href="/tienda" class="tag tag-dark no-underline shadow-hard">todo</a>
      </div>
    </div>
  </section>

  <!-- Featured products -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-24">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 md:mb-12">
      <div>
        <p class="ui-label mb-3">selected noise</p>
        <h2 class="font-marker text-4xl md:text-6xl text-dark m-0 leading-none">drop destacado</h2>
      </div>
      <a href="/tienda" class="font-hand text-sm md:text-base text-mid hover:text-mint no-underline transition-colors uppercase tracking-[0.14em]">ver todo -></a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-8">
      {featured.map((product) => (
        <ProductCard product={product} rotation="rotate-0" />
      ))}
    </div>
  </section>

  <!-- Concept -->
  <section class="border-y border-dark bg-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20 grid grid-cols-1 lg:grid-cols-[1fr_1.15fr] gap-8 lg:gap-12 items-center">
      <div class="surface-panel p-5 md:p-6">
        <img src="/brand/3.png" alt="Drunk Thoughts Club mockup" class="w-full aspect-[4/3] object-cover border border-dark" loading="lazy" />
      </div>
      <div>
        <p class="ui-label mb-4">brand rule / 23</p>
        <h2 class="font-marker text-4xl md:text-6xl text-dark mb-6 leading-none">
          esto es una marca. no una simple tienda.
        </h2>
        <p class="font-hand text-base md:text-lg text-mid leading-relaxed uppercase tracking-[0.06em] mb-8">
          Negro dominante, neón controlado, sticker aesthetics, micro glitch CMYK y composiciones intensas. El caos visual también puede ser identidad.
        </p>
        <a href="/sobre-nosotros" class="btn-dark shadow-hard hover:-translate-y-1 transition-all">leer manifesto</a>
      </div>
    </div>
  </section>

  <!-- Collections -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-24">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8 md:mb-12">
      <div>
        <p class="ui-label mb-3">visual systems</p>
        <h2 class="font-marker text-4xl md:text-6xl text-dark m-0 leading-none">colecciones</h2>
      </div>
      <a href="/colecciones" class="font-hand text-sm md:text-base text-mid hover:text-pink no-underline transition-colors uppercase tracking-[0.14em]">ver todas -></a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {displayCollections.map((col) => {
        const isYellow = col.color === '#FFE600';
        const textColor = isYellow ? '#050505' : '#F5F5F5';
        return (
          <a href="/colecciones" class="surface-panel no-underline group hover:-translate-y-1 transition-transform shadow-hard">
            <div class="aspect-[4/3] overflow-hidden border-b border-dark">
              <img src={col.image} alt={col.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-5 md:p-6" style={`border-top:4px solid ${col.color};`}>
              <p class="font-hand text-xs uppercase tracking-[0.16em] mb-3" style={`color:${col.color};`}>{col.id}</p>
              <h3 class="font-marker text-3xl md:text-4xl mb-3 leading-none" style={`color:${textColor};`}>{col.name}</h3>
              <p class="font-hand text-sm text-mid uppercase tracking-[0.08em] leading-relaxed mb-6">{col.desc}</p>
              <span class="font-hand text-xs text-mint uppercase tracking-[0.16em]">abrir sistema -></span>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-pink border-t border-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-8 md:items-end">
        <div>
          <p class="font-hand text-xs uppercase tracking-[0.2em] text-white/75 mb-4">drop alert</p>
          <h2 class="font-marker text-4xl md:text-6xl text-white mb-4 leading-none">ideas que se quedan pegadas</h2>
          <p class="font-hand text-sm md:text-base text-white/85 uppercase tracking-[0.08em] m-0">Recibe lanzamientos, prototipos y señales antes que el resto.</p>
        </div>
        <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 md:min-w-[420px]">
          <input
            id="newsletter-email"
            type="email"
            placeholder="tu@email.com"
            required
            class="w-full px-5 py-4 font-hand text-sm border border-dark bg-bg text-dark outline-none shadow-hard focus:shadow-hard-lg transition-shadow"
          />
          <button id="newsletter-btn" type="submit" class="btn-dark shadow-hard hover:-translate-y-1 transition-all whitespace-nowrap">
            entrar
          </button>
        </form>
      </div>
      <p id="newsletter-msg" class="font-hand text-sm text-white mt-4 hidden uppercase tracking-[0.08em]"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('newsletter-form') as HTMLFormElement;
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
    const btn = document.getElementById('newsletter-btn') as HTMLButtonElement;
    const msg = document.getElementById('newsletter-msg') as HTMLParagraphElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'enviando...';
      msg.classList.add('hidden');

      try {
        const res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: emailInput.value }),
        });
        const data = await res.json();
        msg.classList.remove('hidden');
        if (data.ok) {
          msg.textContent = data.alreadySubscribed
            ? '¡Ya estabas suscrito/a! 😄'
            : '✓ ¡Suscrito/a! Revisa tu email.';
          form.reset();
        } else {
          msg.textContent = data.error || 'Error al suscribirse';
        }
      } catch {
        msg.textContent = 'Error de red. Inténtalo de nuevo.';
        msg.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'suscribirse';
      }
    });
  </script>

</Layout>
