---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import { getFeaturedProducts } from '../data/products';

const featured = getFeaturedProducts().slice(0, 4);

const rotations = ['rotate(-1.5deg)', 'rotate(1deg)', 'rotate(-0.5deg)', 'rotate(1.5deg)'];
---

<Layout title="No todo lo que ves es lo que parece">

  <!-- ── HERO ── -->
  <section style="background:#fde8f0; border-bottom:2px solid #111; padding:20px 20px 0; overflow:hidden; position:relative;">
    <!-- Decorative circle -->
    <div style="position:absolute; top:-60px; right:-60px; width:220px; height:220px; border-radius:50%; background:rgba(76,201,160,0.18); filter:blur(40px); pointer-events:none;"></div>

    <div style="display:flex; flex-direction:row; gap:16px; align-items:flex-end; max-width:720px; margin:0 auto;">
      <!-- Left content -->
      <div style="flex:1; padding-bottom:20px;">
        <span class="tag tag-mint" style="transform:rotate(-1deg); display:inline-block; margin-bottom:14px; font-size:12px;">
          nueva colección 🌿
        </span>
        <h1 style="font-family:'Permanent Marker',cursive; font-size:clamp(32px,7vw,52px); line-height:1; color:#111; margin:0 0 10px;">
          ROPA / CON
          <span style="color:#f72585;"> (CHISTE)</span>
        </h1>
        <p style="font-family:'Caveat',cursive; font-size:15px; color:#666; margin:0 0 18px; line-height:1.4;">
          (y también sin chiste, pero eso es mentira)
        </p>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <a href="/tienda" class="btn-dark">Ver tienda →</a>
          <a href="/sobre-nosotros" class="btn-outline">¿qué es esto?</a>
        </div>
      </div>

      <!-- Right: product images placeholder -->
      <div style="display:flex; gap:8px; align-items:flex-end; flex-shrink:0;">
        <div class="img-placeholder" style="width:120px; height:150px; transform:rotate(-2deg); flex-shrink:0;">
          <span style="font-size:40px;">👕</span>
        </div>
        <div class="img-placeholder" style="width:90px; height:110px; transform:rotate(3deg); flex-shrink:0;">
          <span style="font-size:32px;">☕</span>
        </div>
      </div>
    </div>

    <!-- Badge absolute -->
    <div style="position:absolute; bottom:16px; left:20px;">
      <span class="tag tag-pink" style="transform:rotate(-1.5deg); font-size:12px; font-weight:700; box-shadow:2px 2px 0 #111;">
        ¡NUEVO DROP! 🔥
      </span>
    </div>
  </section>

  <!-- ── CATEGORÍAS ── -->
  <section style="background:#fff; border-bottom:2px solid #111; padding:16px 20px;">
    <p style="font-family:'Caveat',cursive; font-size:15px; font-weight:700; color:#111; margin:0 0 10px;">
      explorar por tipo
    </p>
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <a href="/tienda?cat=camisetas" class="tag tag-pink" style="transform:rotate(-1deg); text-decoration:none;">👕 camisetas</a>
      <a href="/tienda?cat=sudaderas" class="tag tag-mint" style="transform:rotate(0.5deg); text-decoration:none;">🧥 sudaderas</a>
      <a href="/tienda?cat=tazas"     class="tag tag-light" style="transform:rotate(-0.5deg); text-decoration:none;">☕ tazas</a>
      <a href="/tienda?cat=termos"    class="tag tag-mint" style="transform:rotate(1deg); text-decoration:none;">🧃 termos</a>
      <a href="/tienda"               class="tag tag-dark"  style="transform:rotate(-1deg); text-decoration:none;">📦 todo</a>
    </div>
  </section>

  <!-- ── PRODUCTOS DESTACADOS ── -->
  <section style="padding:20px;">
    <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:14px;">
      <h2 style="font-family:'Permanent Marker',cursive; font-size:20px; color:#111; margin:0;">
        lo más deseado
      </h2>
      <a href="/tienda" style="font-family:'Caveat',cursive; font-size:13px; color:#666; text-decoration:none;">ver todo →</a>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:12px;">
      {featured.map((product, i) => (
        <ProductCard product={product} rotation={rotations[i % rotations.length]} />
      ))}
    </div>
  </section>

  <!-- ── CONCEPTO ── -->
  <section style="background:#e0f7f0; border-top:2px solid #111; border-bottom:2px solid #111; padding:20px;">
    <div style="display:flex; gap:16px; align-items:flex-start; max-width:680px; margin:0 auto;">
      <div class="img-placeholder" style="width:110px; height:110px; flex-shrink:0; transform:rotate(-2deg);">
        <span style="font-size:36px;">🤣</span>
      </div>
      <div>
        <h2 style="font-family:'Permanent Marker',cursive; font-size:20px; color:#111; margin:0 0 8px; line-height:1.2;">
          ropa con personalidad propia
        </h2>
        <p style="font-family:'Caveat',cursive; font-size:14px; color:#666; margin:0 0 12px; line-height:1.5;">
          Diseños de humor y doble sentido. No es moda seria — es un proyecto personal
          con mensajes que revelan algo diferente cuando los miras dos veces.
        </p>
        <a href="/sobre-nosotros" class="btn-primary" style="font-size:13px; padding:6px 14px;">
          saber más →
        </a>
      </div>
    </div>
  </section>

  <!-- ── COLECCIONES ── -->
  <section style="padding:20px;">
    <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:14px;">
      <h2 style="font-family:'Permanent Marker',cursive; font-size:20px; color:#111; margin:0;">
        colecciones
      </h2>
      <a href="/colecciones" style="font-family:'Caveat',cursive; font-size:13px; color:#666; text-decoration:none;">ver todas →</a>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:10px;">
      {[
        { name: 'PATOCHAR',     bg: '#f72585', color: '#fff',  rotate: 'rotate(-1.5deg)', desc: 'cuando el clima es un chiste' },
        { name: 'HIDDEN TRUTH', bg: '#111',    color: '#fff',  rotate: 'rotate(1deg)',    desc: 'la verdad siempre estuvo ahí' },
        { name: 'WAKE UP',      bg: '#4cc9a0', color: '#111',  rotate: 'rotate(-0.5deg)', desc: 'abre los ojos. en serio.' },
      ].map(col => (
        <a
          href="/colecciones"
          style={`background:${col.bg}; color:${col.color}; border:1.5px solid #111; padding:14px 12px; text-decoration:none; display:flex; flex-direction:column; transform:${col.rotate}; transition:transform 0.2s;`}
          class="hover:scale-[1.02]"
        >
          <div class="img-placeholder" style={`width:100%; height:65px; background:rgba(255,255,255,0.12); border-color:${col.color === '#fff' ? 'rgba(255,255,255,0.3)' : 'rgba(0,0,0,0.2)'}; margin-bottom:10px;`}>
          </div>
          <p style="font-family:'Permanent Marker',cursive; font-size:14px; margin:0 0 4px;">{col.name}</p>
          <p style={`font-family:'Caveat',cursive; font-size:11px; margin:0 0 8px; opacity:0.8;`}>{col.desc}</p>
          <span style="font-family:'Caveat',cursive; font-size:11px; opacity:0.7;">ver colección →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── NEWSLETTER ── -->
  <section style="background:#f72585; border-top:2px solid #111; padding:20px;">
    <h2 style="font-family:'Permanent Marker',cursive; font-size:18px; color:#fff; margin:0 0 6px;">
      ¿te cuento los chistes nuevos?
    </h2>
    <p style="font-family:'Caveat',cursive; font-size:14px; color:rgba(255,255,255,0.85); margin:0 0 14px;">
      Suscríbete y recibe los drops antes que nadie.
    </p>
    <form style="display:flex; gap:8px; max-width:380px; flex-wrap:wrap;" onsubmit="return false;">
      <input
        type="email"
        placeholder="tu@email.com"
        style="flex:1; min-width:180px; padding:8px 12px; font-family:'Caveat',cursive; font-size:14px; border:1.5px solid #111; background:#fff; color:#111; outline:none;"
      />
      <button type="submit" class="btn-dark" style="padding:8px 16px; font-size:14px; white-space:nowrap;">
        suscribirse
      </button>
    </form>
  </section>

</Layout>
