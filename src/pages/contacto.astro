---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto" description="Contáctanos para cualquier consulta sobre nuestros audios subliminales.">
  <section class="bg-hero-gradient border-b border-dark-border py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="font-display font-black text-5xl text-white mb-4">Contacto</h1>
      <p class="text-gray-400 text-xl">Estamos aquí para ayudarte en tu viaje de transformación.</p>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Contact Info -->
      <div class="space-y-4">
        {[
          { icon: '📧', title: 'Email', value: 'hola@subliminal.es', sub: 'Respuesta en 24-48h' },
          { icon: '📱', title: 'Instagram', value: '@subliminal.es', sub: 'DMs abiertos' },
          { icon: '💬', title: 'WhatsApp', value: '+34 600 000 000', sub: 'Lun-Vie 9h-18h' },
        ].map(item => (
          <div class="card p-5 flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-primary-900/50 flex items-center justify-center text-xl shrink-0">
              {item.icon}
            </div>
            <div>
              <p class="font-semibold text-white">{item.title}</p>
              <p class="text-primary-300 text-sm">{item.value}</p>
              <p class="text-gray-500 text-xs mt-1">{item.sub}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Form -->
      <div class="lg:col-span-2 card p-8">
        <h2 class="font-display font-bold text-2xl text-white mb-6">Envíanos un mensaje</h2>
        <form class="space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm text-gray-400 mb-1.5">Nombre</label>
              <input type="text" class="input-field" placeholder="Tu nombre" />
            </div>
            <div>
              <label class="block text-sm text-gray-400 mb-1.5">Email</label>
              <input type="email" class="input-field" placeholder="tu@email.com" />
            </div>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Asunto</label>
            <select class="input-field">
              <option value="">Selecciona un asunto</option>
              <option>Consulta sobre un producto</option>
              <option>Problema con mi pedido</option>
              <option>Solicitud de reembolso</option>
              <option>Colaboración</option>
              <option>Otro</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1.5">Mensaje</label>
            <textarea
              rows="5"
              class="input-field resize-none"
              placeholder="Cuéntanos en qué podemos ayudarte..."
            ></textarea>
          </div>
          <button type="submit" class="w-full btn-primary text-lg py-3.5">
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
