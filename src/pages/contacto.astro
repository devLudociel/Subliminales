---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto" description="Contáctanos para cualquier consulta.">
  <section class="surface-panel border-x-0 border-t-0 relative overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 text-center relative z-10">
      <p class="ui-label mb-4">incoming signal</p>
      <h1 class="font-marker text-5xl md:text-7xl text-dark mb-6 leading-none glitch-text">Contacto</h1>
      <p class="font-hand text-sm md:text-base text-mid uppercase tracking-[0.08em] leading-relaxed max-w-2xl mx-auto">Dudas, pedidos, colaboraciones o una idea rara que necesita imprimirse.</p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">
      
      <!-- Contact Info -->
      <div class="space-y-6 lg:space-y-8">
        {[
          { icon: '📧', title: 'Email', value: 'hola@subliminal.es', sub: 'Respuesta en 24-48h' },
          { icon: '📱', title: 'Instagram', value: '@subliminal.es', sub: 'DMs abiertos' },
          { icon: '💬', title: 'WhatsApp', value: '+34 600 000 000', sub: 'Lun-Vie 9h-18h' },
        ].map((item, i) => (
          <div class="bg-white border border-dark p-6 md:p-8 flex items-start gap-6 shadow-hard hover:-translate-y-1 transition-transform">
            <div class="w-16 h-16 bg-mint-light border border-dark flex items-center justify-center shrink-0">
              <span class="font-marker text-2xl text-pink">0{i + 1}</span>
            </div>
            <div>
              <p class="font-marker text-2xl text-dark mb-1">{item.title}</p>
              <p class="font-hand text-sm text-pink uppercase tracking-[0.1em]">{item.value}</p>
              <p class="font-hand text-xs text-mid uppercase tracking-[0.1em] mt-2">{item.sub}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Form -->
      <div class="lg:col-span-2 bg-white border border-dark p-8 md:p-12 shadow-hard">
        <h2 class="font-marker text-4xl md:text-5xl text-dark mb-8">Enviar señal</h2>
        <form class="space-y-6 md:space-y-8">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
            <div>
              <label class="block ui-label mb-2">Nombre</label>
              <input type="text" class="w-full px-6 py-4 font-hand text-sm border border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" placeholder="Tu nombre" />
            </div>
            <div>
              <label class="block ui-label mb-2">Email</label>
              <input type="email" class="w-full px-6 py-4 font-hand text-sm border border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all" placeholder="tu@email.com" />
            </div>
          </div>
          <div>
            <label class="block ui-label mb-2">Asunto</label>
            <select class="w-full px-6 py-4 font-hand text-sm border border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all appearance-none cursor-pointer">
              <option value="">Selecciona un asunto</option>
              <option>Consulta sobre un producto</option>
              <option>Problema con mi pedido</option>
              <option>Solicitud de devolución</option>
              <option>Colaboración / Idea de diseño</option>
              <option>Otro</option>
            </select>
          </div>
          <div>
            <label class="block ui-label mb-2">Mensaje</label>
            <textarea
              rows="5"
              class="w-full px-6 py-4 font-hand text-sm border border-dark bg-bg text-dark outline-none focus:bg-white focus:shadow-hard transition-all resize-y"
              placeholder="Cuéntanos..."
            ></textarea>
          </div>
          <button type="submit" class="w-full bg-pink text-white font-hand text-sm uppercase tracking-[0.14em] py-5 border border-dark shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all">
            Enviar mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
