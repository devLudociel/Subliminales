---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProductBySlug, getProductsByCategory } from '../../data/products';

const { slug } = Astro.params;
const product = await getProductBySlug(slug as string);

if (!product) {
  return Astro.redirect('/tienda');
}

const related = (await getProductsByCategory(product.category))
  .filter(p => p.id !== product.id)
  .slice(0, 3);

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;

const categoryEmoji: Record<string, string> = {
  camisetas: '👕', sudaderas: '🧥', tazas: '☕',
  termos: '🧃', posters: '🖼️', accesorios: '🎁',
};

const relRotations = ['-rotate-2', 'rotate-1', '-rotate-1'];

const colorMap: Record<string, string> = {
  'Negro':      '#111111',
  'Blanco':     '#ffffff',
  'Gris oscuro':'#444444',
  'Rojo':       '#e63946',
  'Azul':       '#1d6fa4',
  'Verde':      '#2d6a4f',
  'Beige':      '#d4b896',
  'Rosa':       '#f72585',
  'Naranja':    '#ff9f1c',
  'Amarillo':   '#ffd60a',
  'Morado':     '#7209b7',
};
---

<Layout title={product.name} description={product.description}>

  <!-- Breadcrumb -->
  <nav class="bg-white border-b-2 border-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <span class="font-hand text-xl text-mid">
        <a href="/" class="text-mid no-underline hover:text-dark transition-colors">inicio</a>
        {' → '}
        <a href="/tienda" class="text-mid no-underline hover:text-dark transition-colors">tienda</a>
        {' → '}
        <a href={`/tienda?cat=${product.category}`} class="text-mid no-underline hover:text-dark transition-colors">{product.category}</a>
        {' → '}
        <span class="text-dark font-bold">{product.name}</span>
      </span>
    </div>
  </nav>

  <!-- Main product section -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20">

      <!-- Gallery left -->
      <div>
        <!-- Main image -->
        <div class="w-full aspect-[4/5] -rotate-1 border-2 border-dark mb-6 relative overflow-hidden shadow-hard rounded-xl bg-white flex items-center justify-center" id="main-img-wrap">
          {product.image ? (
            <img src={product.image} alt={product.name}
              class="w-full h-full object-cover" id="main-img" />
          ) : (
            <span class="text-8xl md:text-9xl">{categoryEmoji[product.category] ?? '📦'}</span>
          )}
          {product.isNew && (
            <span class="absolute top-4 right-4 bg-mint text-dark font-hand text-lg px-4 py-1 border-2 border-dark rotate-2 shadow-hard">
              NEW
            </span>
          )}
          {product.bestseller && !product.isNew && (
            <span class="absolute top-4 right-4 bg-pink text-white font-hand text-lg px-4 py-1 border-2 border-dark rotate-2 shadow-hard">
              TOP
            </span>
          )}
          {discount && (
            <span class="absolute top-4 left-4 bg-pink text-white font-hand text-lg px-4 py-1 border-2 border-dark shadow-hard">
              -{discount}%
            </span>
          )}
        </div>
        <!-- Thumbnails -->
        {product.images && product.images.length > 1 && (
          <div class="flex gap-4 overflow-x-auto pb-1">
            {product.images.map((img, i) => (
              <button type="button"
                class="thumb-btn shrink-0 w-20 h-20 md:w-24 md:h-24 cursor-pointer border-2 border-dark shadow-hard hover:-translate-y-1 transition-transform rounded-lg overflow-hidden bg-white p-0"
                data-src={img}
                style={i === 0 ? 'border-color:#f72585;' : ''}>
                <img src={img} alt={`${product.name} ${i+1}`} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info right -->
      <div class="flex flex-col gap-6 md:gap-8">
        <!-- Collection tag -->
        {product.collection && (
          <span class="tag tag-mint -rotate-1 self-start text-lg shadow-hard px-4 py-1">
            {product.collection.replace('-', ' ')}
          </span>
        )}

        <!-- Name -->
        <h1 class="font-marker text-4xl md:text-5xl lg:text-6xl text-dark m-0 leading-none">
          {product.name}
        </h1>

        <!-- Short desc -->
        <p class="font-hand text-2xl md:text-3xl text-mid m-0 leading-relaxed">
          {product.description}
        </p>

        <!-- Price -->
        <div class="flex items-baseline gap-4">
          <span class="font-marker text-4xl md:text-5xl text-dark">
            {product.price.toFixed(2)}€
          </span>
          {product.originalPrice && (
            <span class="font-hand text-2xl text-mid line-through opacity-70">
              {product.originalPrice.toFixed(2)}€
            </span>
          )}
        </div>

        <!-- Size selector -->
        {product.sizes && (
          <div>
            <p class="font-hand text-2xl text-dark mb-4 font-bold">talla:</p>
            <div class="flex gap-3 flex-wrap" id="size-selector">
              {product.sizes.map((size, idx) => (
                <button
                  class="size-btn font-hand text-xl md:text-2xl px-6 py-3 border-2 border-dark cursor-pointer transition-all hover:scale-105 shadow-hard rounded-lg"
                  data-size={size}
                  style={idx === 0 ? 'background:#f72585; color:#fff;' : 'background:#fff; color:#111;'}
                >
                  {size}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Color selector -->
        {product.colors && (
          <div>
            <p class="font-hand text-2xl text-dark mb-4 font-bold">color:</p>
            <div class="flex gap-4 flex-wrap">
              {product.colors.map((color) => (
                <div
                  class="w-10 h-10 md:w-12 md:h-12 rounded-full border-[3px] border-dark cursor-pointer hover:scale-110 transition-transform shadow-hard"
                  style={`background:${colorMap[color] ?? '#ccc'};`}
                  title={color}
                ></div>
              ))}
            </div>
          </div>
        )}

        <!-- Add to cart buttons -->
        <div class="flex flex-col gap-4 mt-4">
          <button
            id="add-to-cart-btn"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.price}
            class="bg-pink text-white border-2 border-dark font-hand text-2xl md:text-3xl py-4 md:py-5 cursor-pointer w-full text-center shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all rounded-lg"
          >
            añadir al carrito 🛒
          </button>
          <a
            href="/carrito"
            class="bg-dark text-mint border-2 border-dark font-hand text-2xl md:text-3xl py-4 md:py-5 cursor-pointer w-full text-center no-underline block shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all rounded-lg"
          >
            comprar ahora →
          </a>
        </div>

        <!-- Guarantees -->
        <p class="font-hand text-xl text-mid m-0">
          ✓ envío gratis +50€ · ✓ devolución 30 días
        </p>
      </div>
    </div>
  </div>

  <!-- Description / el chiste -->
  <section class="bg-white border-y-2 border-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <h2 class="font-marker text-4xl md:text-5xl text-dark mb-8">
        el chiste
      </h2>
      <p class="font-hand text-2xl md:text-3xl text-mid leading-relaxed mb-10">
        {product.longDescription}
      </p>
      <!-- Feature tags -->
      <div class="flex gap-4 flex-wrap">
        <span class="tag bg-mint-light text-dark border-2 border-dark text-lg md:text-xl px-5 py-2 shadow-hard">100% algodón</span>
        <span class="tag bg-mint-light text-dark border-2 border-dark text-lg md:text-xl px-5 py-2 shadow-hard">fabricado en España</span>
        <span class="tag bg-mint-light text-dark border-2 border-dark text-lg md:text-xl px-5 py-2 shadow-hard">lavable a 30°</span>
        {product.tags.slice(0, 2).map(t => (
          <span class="tag bg-light-pink text-dark border-2 border-dark text-lg md:text-xl px-5 py-2 shadow-hard">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Related products -->
  {related.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <h2 class="font-marker text-4xl md:text-5xl text-dark mb-10">
        también te puede gustar
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6 md:gap-10">
        {related.map((p, i) => (
          <div class={`transform ${relRotations[i % relRotations.length]} hover:z-10 hover:rotate-0 transition-transform duration-300`}>
            <ProductCard product={p} rotation="rotate-0" />
          </div>
        ))}
      </div>
    </section>
  )}

</Layout>

<script>
  import { addToCart } from '../../store/cart';

  // Add to cart
  const btn = document.getElementById('add-to-cart-btn');
  btn?.addEventListener('click', () => {
    addToCart({
      id: btn.dataset.productId!,
      name: btn.dataset.productName!,
      price: parseFloat(btn.dataset.productPrice!),
      image: '',
    });
    const orig = btn.innerHTML;
    btn.innerHTML = '✓ añadido al carrito';
    setTimeout(() => { btn.innerHTML = orig; }, 1800);
  });

  // Thumbnail gallery
  document.querySelectorAll('.thumb-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = (btn as HTMLButtonElement).dataset.src!;
      const mainImg = document.getElementById('main-img') as HTMLImageElement | null;
      if (mainImg) mainImg.src = src;
      document.querySelectorAll('.thumb-btn').forEach(b => (b as HTMLElement).style.borderColor = '');
      (btn as HTMLElement).style.borderColor = '#f72585';
    });
  });

  // Size selector
  document.querySelectorAll('.size-btn').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.size-btn').forEach(x => {
        (x as HTMLButtonElement).style.background = '#fff';
        (x as HTMLButtonElement).style.color = '#111';
      });
      (b as HTMLButtonElement).style.background = '#f72585';
      (b as HTMLButtonElement).style.color = '#fff';
    });
  });
</script>
