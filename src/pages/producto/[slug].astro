---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, getProductBySlug, getProductsByCategory } from '../../data/products';

export async function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug);

if (!product) {
  return Astro.redirect('/tienda');
}

const related = getProductsByCategory(product.category)
  .filter(p => p.id !== product.id)
  .slice(0, 4);

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;

const categoryEmojis: Record<string, string> = {
  autoestima: '💪',
  abundancia: '💰',
  amor: '❤️',
  salud: '🌿',
  exito: '🏆',
  paz: '🧘',
  sueno: '🌙',
};
---

<Layout title={product.name} description={product.description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
      <a href="/" class="hover:text-gray-300 transition-colors">Inicio</a>
      <span>›</span>
      <a href="/tienda" class="hover:text-gray-300 transition-colors">Tienda</a>
      <span>›</span>
      <span class="text-gray-300">{product.name}</span>
    </nav>

    <!-- Product -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
      <!-- Visual -->
      <div class="relative">
        <div class="aspect-square rounded-3xl bg-gradient-to-br from-primary-900/50 to-dark border border-dark-border flex items-center justify-center">
          <div class="text-center">
            <div class="w-32 h-32 rounded-3xl bg-gradient-to-br from-primary-500/30 to-accent/30 flex items-center justify-center text-7xl mx-auto mb-6 animate-float">
              {categoryEmojis[product.category] || '🎵'}
            </div>
            <span class="badge-primary">{product.duration}</span>
          </div>
        </div>

        <!-- Formats badge -->
        <div class="absolute bottom-4 left-4 right-4 flex gap-2">
          {product.format.map(f => (
            <span class="badge bg-black/70 text-gray-300 backdrop-blur-sm text-xs px-3 py-1.5">
              🎵 {f}
            </span>
          ))}
        </div>
      </div>

      <!-- Info -->
      <div class="flex flex-col">
        <!-- Badges -->
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="badge-primary">{product.category}</span>
          {product.bestseller && <span class="badge-accent">⭐ Bestseller</span>}
          {discount && <span class="badge bg-red-900/50 text-red-300 border border-red-700/30">-{discount}% descuento</span>}
        </div>

        <h1 class="font-display font-black text-4xl text-white mb-4 leading-tight">
          {product.name}
        </h1>

        <p class="text-gray-400 text-lg leading-relaxed mb-6">
          {product.longDescription}
        </p>

        <!-- Price -->
        <div class="flex items-baseline gap-3 mb-8">
          <span class="font-display font-black text-4xl text-white">{product.price.toFixed(2)}€</span>
          {product.originalPrice && (
            <span class="text-gray-500 line-through text-xl">{product.originalPrice.toFixed(2)}€</span>
          )}
          {discount && (
            <span class="text-green-400 text-sm font-semibold">Ahorras {(product.originalPrice! - product.price).toFixed(2)}€</span>
          )}
        </div>

        <!-- CTA -->
        <div class="space-y-3 mb-8">
          <button
            id="add-to-cart"
            class="w-full btn-primary text-lg py-4"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.price}
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Añadir al carrito
          </button>
          <a href="/checkout" class="w-full btn-secondary text-lg py-4 block text-center" id="buy-now">
            Comprar ahora
          </a>
        </div>

        <!-- Guarantees -->
        <div class="grid grid-cols-3 gap-3 p-4 rounded-2xl bg-dark-card border border-dark-border">
          <div class="text-center">
            <p class="text-2xl mb-1">⚡</p>
            <p class="text-gray-400 text-xs">Descarga<br/>inmediata</p>
          </div>
          <div class="text-center border-x border-dark-border">
            <p class="text-2xl mb-1">🔒</p>
            <p class="text-gray-400 text-xs">Pago<br/>seguro</p>
          </div>
          <div class="text-center">
            <p class="text-2xl mb-1">✅</p>
            <p class="text-gray-400 text-xs">Garantía<br/>30 días</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Benefits -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      <div class="card p-8">
        <h2 class="font-display font-bold text-2xl text-white mb-6">Beneficios</h2>
        <ul class="space-y-4">
          {product.benefits.map(benefit => (
            <li class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-green-900/50 border border-green-700/30 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-gray-300">{benefit}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="card p-8">
        <h2 class="font-display font-bold text-2xl text-white mb-6">Detalles</h2>
        <dl class="space-y-4">
          <div class="flex justify-between items-center py-2 border-b border-dark-border">
            <dt class="text-gray-500">Duración</dt>
            <dd class="text-white font-medium">{product.duration}</dd>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-dark-border">
            <dt class="text-gray-500">Formato</dt>
            <dd class="text-white font-medium">{product.format.join(', ')}</dd>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-dark-border">
            <dt class="text-gray-500">Categoría</dt>
            <dd class="text-white font-medium capitalize">{product.category}</dd>
          </div>
          <div class="flex justify-between items-center py-2 border-b border-dark-border">
            <dt class="text-gray-500">Entrega</dt>
            <dd class="text-green-400 font-medium">Descarga inmediata</dd>
          </div>
          <div class="flex justify-between items-center py-2">
            <dt class="text-gray-500">Garantía</dt>
            <dd class="text-white font-medium">30 días devolución</dd>
          </div>
        </dl>

        <div class="mt-6 flex flex-wrap gap-2">
          {product.tags.map(tag => (
            <span class="badge-primary text-xs">#{tag}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Related -->
    {related.length > 0 && (
      <div>
        <h2 class="section-title mb-2">También te puede interesar</h2>
        <p class="section-subtitle mb-8">Más programas de {product.category}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {related.map(p => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  import { addToCart } from '../../store/cart';

  const btn = document.getElementById('add-to-cart') as HTMLButtonElement;
  btn?.addEventListener('click', () => {
    addToCart({
      id: btn.dataset.productId!,
      name: btn.dataset.productName!,
      price: parseFloat(btn.dataset.productPrice!),
      image: '',
    });
    const orig = btn.innerHTML;
    btn.innerHTML = '✓ Añadido al carrito';
    btn.classList.add('opacity-75');
    setTimeout(() => {
      btn.innerHTML = orig;
      btn.classList.remove('opacity-75');
    }, 2000);
  });

  // Buy now: add to cart and go to checkout
  const buyNow = document.getElementById('buy-now');
  buyNow?.addEventListener('click', (e) => {
    e.preventDefault();
    addToCart({
      id: btn.dataset.productId!,
      name: btn.dataset.productName!,
      price: parseFloat(btn.dataset.productPrice!),
      image: '',
    });
    window.location.href = '/checkout';
  });
</script>
