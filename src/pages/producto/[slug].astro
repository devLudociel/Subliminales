---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, getProductBySlug, getProductsByCategory } from '../../data/products';

export async function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug);

if (!product) {
  return Astro.redirect('/tienda');
}

const related = getProductsByCategory(product.category)
  .filter(p => p.id !== product.id)
  .slice(0, 3);

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;

const categoryEmoji: Record<string, string> = {
  camisetas: '👕', sudaderas: '🧥', tazas: '☕',
  termos: '🧃', posters: '🖼️', accesorios: '🎁',
};

const relRotations = ['rotate(-1.5deg)', 'rotate(1deg)', 'rotate(-0.5deg)'];

const colorMap: Record<string, string> = {
  'Negro': '#111', 'Blanco': '#fff', 'Gris oscuro': '#444',
};
---

<Layout title={product.name} description={product.description}>

  <!-- Breadcrumb -->
  <nav style="background:#fff; border-bottom:1px solid #eee; padding:8px 20px;">
    <span style="font-family:'Caveat',cursive; font-size:12px; color:#666;">
      <a href="/" style="color:#666; text-decoration:none;">inicio</a>
      {' → '}
      <a href="/tienda" style="color:#666; text-decoration:none;">tienda</a>
      {' → '}
      <a href={`/tienda?cat=${product.category}`} style="color:#666; text-decoration:none;">{product.category}</a>
      {' → '}
      <span style="color:#111;">{product.name}</span>
    </span>
  </nav>

  <!-- Main product section -->
  <div style="padding:20px; max-width:900px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;" class="product-grid">

      <!-- Gallery left -->
      <div>
        <!-- Main image -->
        <div class="img-placeholder" style="width:100%; aspect-ratio:4/5; transform:rotate(-1deg); border:2px solid #111; margin-bottom:10px; position:relative;">
          <span style="font-size:60px;">{categoryEmoji[product.category] ?? '📦'}</span>
          {product.isNew && (
            <span style="position:absolute; top:10px; right:10px; background:#4cc9a0; color:#111; font-family:'Caveat',cursive; font-size:12px; padding:3px 8px; border:1.5px solid #111; transform:rotate(1.5deg);">
              NEW
            </span>
          )}
          {product.bestseller && !product.isNew && (
            <span style="position:absolute; top:10px; right:10px; background:#f72585; color:#fff; font-family:'Caveat',cursive; font-size:12px; padding:3px 8px; border:1.5px solid #111; transform:rotate(1.5deg);">
              TOP
            </span>
          )}
          {discount && (
            <span style="position:absolute; top:10px; left:10px; background:#f72585; color:#fff; font-family:'Caveat',cursive; font-size:12px; padding:3px 8px; border:1.5px solid #111;">
              -{discount}%
            </span>
          )}
        </div>
        <!-- Thumbnails -->
        <div style="display:flex; gap:8px;">
          {[1,2,3].map(i => (
            <div class="img-placeholder" style="width:60px; height:60px; cursor:pointer; border:1.5px solid #111;">
              <span style="font-size:18px;">{categoryEmoji[product.category] ?? '📦'}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Info right -->
      <div style="display:flex; flex-direction:column; gap:12px;">
        <!-- Collection tag -->
        {product.collection && (
          <span class="tag tag-mint" style="transform:rotate(-1deg); align-self:flex-start; font-size:11px;">
            {product.collection.replace('-', ' ')}
          </span>
        )}

        <!-- Name -->
        <h1 style="font-family:'Permanent Marker',cursive; font-size:clamp(22px,5vw,32px); color:#111; margin:0; line-height:1.1;">
          {product.name}
        </h1>

        <!-- Short desc -->
        <p style="font-family:'Caveat',cursive; font-size:15px; color:#666; margin:0; line-height:1.5;">
          {product.description}
        </p>

        <!-- Price -->
        <div style="display:flex; align-items:baseline; gap:8px;">
          <span style="font-family:'Caveat',cursive; font-size:22px; font-weight:700; color:#111;">
            {product.price.toFixed(2)}€
          </span>
          {product.originalPrice && (
            <span style="font-family:'Caveat',cursive; font-size:14px; color:#999; text-decoration:line-through;">
              {product.originalPrice.toFixed(2)}€
            </span>
          )}
        </div>

        <!-- Size selector -->
        {product.sizes && (
          <div>
            <p style="font-family:'Caveat',cursive; font-size:13px; color:#666; margin:0 0 6px;">talla:</p>
            <div style="display:flex; gap:6px; flex-wrap:wrap;" id="size-selector">
              {product.sizes.map((size, idx) => (
                <button
                  class="size-btn"
                  data-size={size}
                  style={`font-family:'Caveat',cursive; font-size:13px; padding:4px 10px; border:1.5px solid #111; cursor:pointer; ${idx === 0 ? 'background:#f72585; color:#fff;' : 'background:#fff; color:#111;'}`}
                >
                  {size}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Color selector -->
        {product.colors && (
          <div>
            <p style="font-family:'Caveat',cursive; font-size:13px; color:#666; margin:0 0 6px;">color:</p>
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
              {product.colors.map((color) => (
                <div
                  style={`width:22px; height:22px; border-radius:50%; background:${colorMap[color] ?? '#ccc'}; border:2px solid #111; cursor:pointer;`}
                  title={color}
                ></div>
              ))}
            </div>
          </div>
        )}

        <!-- Add to cart buttons -->
        <div style="display:flex; flex-direction:column; gap:8px; margin-top:4px;">
          <button
            id="add-to-cart-btn"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.price}
            style="background:#f72585; color:#fff; border:1.5px solid #111; font-family:'Caveat',cursive; font-size:16px; padding:10px 20px; cursor:pointer; width:100%; text-align:center;"
          >
            añadir al carrito 🛒
          </button>
          <a
            href="/carrito"
            style="background:#111; color:#4cc9a0; border:1.5px solid #111; font-family:'Caveat',cursive; font-size:15px; padding:9px 20px; cursor:pointer; width:100%; text-align:center; text-decoration:none; display:block;"
          >
            comprar ahora →
          </a>
        </div>

        <!-- Guarantees -->
        <p style="font-family:'Caveat',cursive; font-size:12px; color:#666; margin:0;">
          ✓ envío gratis +50€ · ✓ devolución 30 días
        </p>
      </div>
    </div>
  </div>

  <!-- Description / el chiste -->
  <section style="background:#fff; border-top:2px solid #111; border-bottom:2px solid #111; padding:20px; max-width:900px; margin:0 auto;">
    <h2 style="font-family:'Permanent Marker',cursive; font-size:18px; color:#111; margin:0 0 10px;">
      el chiste
    </h2>
    <p style="font-family:'Caveat',cursive; font-size:15px; color:#666; line-height:1.6; margin:0 0 14px;">
      {product.longDescription}
    </p>
    <!-- Feature tags -->
    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <span class="tag" style="background:#e0f7f0; color:#111; font-size:12px;">100% algodón</span>
      <span class="tag" style="background:#e0f7f0; color:#111; font-size:12px;">fabricado en España</span>
      <span class="tag" style="background:#e0f7f0; color:#111; font-size:12px;">lavable a 30°</span>
      {product.tags.slice(0, 2).map(t => (
        <span class="tag" style="background:#fde8f0; color:#111; font-size:12px;">{t}</span>
      ))}
    </div>
  </section>

  <!-- Related products -->
  {related.length > 0 && (
    <section style="padding:20px; max-width:900px; margin:0 auto;">
      <h2 style="font-family:'Permanent Marker',cursive; font-size:18px; color:#111; margin:0 0 14px;">
        también te puede gustar
      </h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:12px;">
        {related.map((p, i) => (
          <ProductCard product={p} rotation={relRotations[i % relRotations.length]} />
        ))}
      </div>
    </section>
  )}

</Layout>

<style>
  @media (max-width: 600px) {
    .product-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  import { addToCart } from '../../store/cart';

  // Add to cart
  const btn = document.getElementById('add-to-cart-btn');
  btn?.addEventListener('click', () => {
    addToCart({
      id: btn.dataset.productId!,
      name: btn.dataset.productName!,
      price: parseFloat(btn.dataset.productPrice!),
      image: '',
    });
    const orig = btn.innerHTML;
    btn.innerHTML = '✓ añadido al carrito';
    setTimeout(() => { btn.innerHTML = orig; }, 1800);
  });

  // Size selector
  document.querySelectorAll('.size-btn').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('.size-btn').forEach(x => {
        (x as HTMLButtonElement).style.background = '#fff';
        (x as HTMLButtonElement).style.color = '#111';
      });
      (b as HTMLButtonElement).style.background = '#f72585';
      (b as HTMLButtonElement).style.color = '#fff';
    });
  });
</script>
