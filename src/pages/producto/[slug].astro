---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, getProductBySlug, getProductsByCategory } from '../../data/products';

export async function getStaticPaths() {
  return products.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug);

if (!product) {
  return Astro.redirect('/tienda');
}

const related = getProductsByCategory(product.category)
  .filter(p => p.id !== product.id)
  .slice(0, 4);

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;
---

<Layout title={product.name} description={product.description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-xs font-alt text-ink-faint mb-10 uppercase tracking-wider">
      <a href="/" class="hover:text-ink-muted transition-colors">Inicio</a>
      <span>›</span>
      <a href="/tienda" class="hover:text-ink-muted transition-colors">Tienda</a>
      <span>›</span>
      <a href={`/tienda?cat=${product.category}`} class="hover:text-ink-muted transition-colors capitalize">{product.category}</a>
      <span>›</span>
      <span class="text-ink-muted">{product.name}</span>
    </nav>

    <!-- Product grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20">

      <!-- Galería izquierda -->
      <div class="space-y-3">
        <!-- Imagen principal -->
        <div class="relative aspect-[4/5] bg-bg-card border border-white/5 overflow-hidden">
          <!-- Placeholder visual -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="text-center select-none">
              <div class="font-display font-black text-[100px] leading-none text-white/5 mb-2">
                {product.category === 'camisetas' && '◻'}
                {product.category === 'sudaderas' && '▣'}
                {product.category === 'tazas' && '◎'}
                {product.category === 'termos' && '▥'}
                {product.category === 'posters' && '▧'}
                {product.category === 'accesorios' && '◈'}
              </div>
              <p class="font-display text-xs text-ink-faint uppercase tracking-widest">
                {product.name}
              </p>
            </div>
          </div>
          <!-- Corner accents -->
          <span class="absolute top-0 left-0 w-6 h-6 border-t border-l border-brand/40"></span>
          <span class="absolute top-0 right-0 w-6 h-6 border-t border-r border-brand/40"></span>
          <span class="absolute bottom-0 left-0 w-6 h-6 border-b border-l border-brand/40"></span>
          <span class="absolute bottom-0 right-0 w-6 h-6 border-b border-r border-brand/40"></span>
          <!-- Badges -->
          <div class="absolute top-3 left-3 flex flex-col gap-1.5 z-10">
            {product.isNew && <span class="badge-neon">NEW</span>}
            {product.bestseller && <span class="badge-brand">TOP</span>}
            {discount && <span class="badge bg-neo/15 text-neo border border-neo/30">-{discount}%</span>}
          </div>
        </div>
        <!-- Thumbnails placeholder -->
        <div class="grid grid-cols-4 gap-2">
          {[1,2,3,4].map(i => (
            <div class="aspect-square bg-bg-card border border-white/5 hover:border-brand/40 cursor-pointer transition-colors flex items-center justify-center">
              <span class="text-ink-faint text-xs font-display">{i}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Info derecha -->
      <div class="flex flex-col">

        <!-- Colección -->
        {product.collection && (
          <span class="label-section text-brand mb-3">
            {product.collection.replace('-', ' ').toUpperCase()} — {product.category.toUpperCase()}
          </span>
        )}

        <!-- Nombre -->
        <h1 class="font-display font-black text-4xl sm:text-5xl text-ink uppercase tracking-tight leading-none mb-4">
          {product.name}
        </h1>

        <!-- Descripción corta -->
        <p class="font-alt text-ink-muted text-base leading-relaxed mb-6 italic">
          "{product.description}"
        </p>

        <!-- Precio -->
        <div class="flex items-baseline gap-3 mb-8">
          <span class="font-display font-black text-4xl text-ink">{product.price.toFixed(2)}€</span>
          {product.originalPrice && (
            <span class="font-alt text-ink-faint line-through text-xl">{product.originalPrice.toFixed(2)}€</span>
          )}
          {discount && (
            <span class="badge-neo text-xs">Ahorras {(product.originalPrice! - product.price).toFixed(2)}€</span>
          )}
        </div>

        <!-- Selector de talla (si aplica) -->
        {product.sizes && product.sizes.length > 0 && (
          <div class="mb-6">
            <p class="label-section mb-3">Talla</p>
            <div class="flex flex-wrap gap-2">
              {product.sizes.map(size => (
                <button class="px-3 py-2 border border-white/10 text-ink-muted text-sm font-alt hover:border-brand hover:text-brand transition-all duration-150 uppercase tracking-wider">
                  {size}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Selector de color (si aplica) -->
        {product.colors && product.colors.length > 0 && (
          <div class="mb-8">
            <p class="label-section mb-3">Color</p>
            <div class="flex flex-wrap gap-2">
              {product.colors.map(color => (
                <button class="px-4 py-2 border border-white/10 text-ink-muted text-sm font-alt hover:border-brand hover:text-brand transition-all duration-150">
                  {color}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- CTAs -->
        <div class="space-y-3 mb-8">
          <button
            id="add-to-cart"
            class="w-full btn-primary text-base py-4"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.price}
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Añadir al carrito
          </button>
          <a href="/checkout" class="w-full btn-outline text-base py-4 block text-center" id="buy-now">
            Comprar ahora
          </a>
        </div>

        <!-- Garantías -->
        <div class="grid grid-cols-3 gap-3 p-4 bg-bg-card border border-white/5">
          <div class="text-center">
            <p class="font-display text-base mb-1 text-brand">◎</p>
            <p class="font-alt text-ink-faint text-xs leading-tight">Envío<br/>nacional</p>
          </div>
          <div class="text-center border-x border-white/5">
            <p class="font-display text-base mb-1 text-neon">◈</p>
            <p class="font-alt text-ink-faint text-xs leading-tight">Pago<br/>seguro</p>
          </div>
          <div class="text-center">
            <p class="font-display text-base mb-1 text-neo">◻</p>
            <p class="font-alt text-ink-faint text-xs leading-tight">30 días<br/>devolución</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Descripción larga + Mensaje oculto -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-20">

      <!-- Descripción -->
      <div class="bg-bg-card border border-white/5 p-8">
        <span class="label-section text-neon block mb-4">El diseño</span>
        <h2 class="font-display font-bold text-xl text-ink uppercase tracking-wide mb-4">
          Descripción
        </h2>
        <p class="font-alt text-ink-muted text-sm leading-relaxed">
          {product.longDescription}
        </p>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mt-6">
          {product.tags.map(tag => (
            <span class="badge-brand text-xs">#{tag}</span>
          ))}
        </div>
      </div>

      <!-- Interacción mensaje oculto -->
      <div class="bg-bg-card border border-brand/20 p-8 relative overflow-hidden group">
        <span class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-brand to-transparent"></span>
        <span class="label-section text-brand block mb-4">Psicología visual</span>
        <h2 class="font-display font-bold text-xl text-ink uppercase tracking-wide mb-4">
          ¿Ves el mensaje oculto?
        </h2>
        <p class="font-alt text-ink-muted text-sm leading-relaxed mb-6">
          Este diseño contiene un mensaje oculto que se revela cuando observas el gráfico detenidamente.
          La mayoría de personas lo descubre en segundos.
        </p>

        <!-- Botón reveal -->
        <button
          id="reveal-btn"
          class="btn-primary text-sm px-6 py-3"
        >
          Revelar mensaje
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </button>

        <!-- Mensaje revelado (oculto) -->
        <div id="hidden-message" class="hidden mt-4 p-4 border border-neon/30 bg-neon/5">
          <p class="font-display text-sm text-neon uppercase tracking-widest text-center">
            "Tu mente ya lo vio."
          </p>
        </div>
      </div>
    </div>

    <!-- Productos relacionados -->
    {related.length > 0 && (
      <div>
        <div class="flex items-end justify-between mb-8">
          <div>
            <span class="label-section text-brand block mb-2">Puede que te interese</span>
            <h2 class="title-section">Más de {product.category}</h2>
          </div>
          <a href={`/tienda?cat=${product.category}`} class="hidden sm:flex btn-ghost text-sm font-alt tracking-wider">
            Ver todos →
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
          {related.map(p => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<script>
  import { addToCart } from '../../store/cart';

  const btn = document.getElementById('add-to-cart') as HTMLButtonElement;
  btn?.addEventListener('click', () => {
    addToCart({
      id: btn.dataset.productId!,
      name: btn.dataset.productName!,
      price: parseFloat(btn.dataset.productPrice!),
      image: '',
    });
    const orig = btn.innerHTML;
    btn.innerHTML = '✓ Añadido al carrito';
    btn.classList.add('opacity-75');
    setTimeout(() => {
      btn.innerHTML = orig;
      btn.classList.remove('opacity-75');
    }, 2000);
  });

  // Buy now
  const buyNow = document.getElementById('buy-now');
  buyNow?.addEventListener('click', (e) => {
    e.preventDefault();
    addToCart({
      id: btn.dataset.productId!,
      name: btn.dataset.productName!,
      price: parseFloat(btn.dataset.productPrice!),
      image: '',
    });
    window.location.href = '/checkout';
  });

  // Reveal hidden message
  const revealBtn = document.getElementById('reveal-btn');
  const hiddenMsg = document.getElementById('hidden-message');
  revealBtn?.addEventListener('click', () => {
    hiddenMsg?.classList.remove('hidden');
    hiddenMsg?.classList.add('animate-reveal');
    revealBtn.textContent = '✓ Lo ves ahora';
    revealBtn.classList.add('opacity-50', 'pointer-events-none');
  });
</script>
