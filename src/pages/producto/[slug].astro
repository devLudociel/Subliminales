---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import WishlistButton from '../../components/WishlistButton';
import ProductReviews from '../../components/ProductReviews';
import { getProductBySlug, getProductsByCategory } from '../../data/products';

const { slug } = Astro.params;
const product = await getProductBySlug(slug as string);

if (!product) {
  return Astro.redirect('/tienda');
}

const related = (await getProductsByCategory(product.category))
  .filter(p => p.id !== product.id)
  .slice(0, 3);

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;

const categoryEmoji: Record<string, string> = {
  camisetas: '👕', sudaderas: '🧥', tazas: '☕',
  termos: '🧃', posters: '🖼️', accesorios: '🎁',
};

const colorMap: Record<string, string> = {
  'Negro':      '#111111',
  'Blanco':     '#ffffff',
  'Gris oscuro':'#444444',
  'Rojo':       '#e63946',
  'Azul':       '#1d6fa4',
  'Verde':      '#2d6a4f',
  'Beige':      '#d4b896',
  'Rosa':       '#f72585',
  'Naranja':    '#ff9f1c',
  'Amarillo':   '#ffd60a',
  'Morado':     '#7209b7',
};
---

<Layout title={product.name} description={product.description}>

  <!-- Breadcrumb -->
  <nav class="bg-bg border-b border-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <span class="font-hand text-xs md:text-sm text-mid uppercase tracking-[0.14em]">
        <a href="/" class="text-mid no-underline hover:text-dark transition-colors">inicio</a>
        {' / '}
        <a href="/tienda" class="text-mid no-underline hover:text-dark transition-colors">tienda</a>
        {' / '}
        <a href={`/tienda?cat=${product.category}`} class="text-mid no-underline hover:text-dark transition-colors">{product.category}</a>
        {' / '}
        <span class="text-dark font-bold">{product.name}</span>
      </span>
    </div>
  </nav>

  <!-- Main product section -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20">

      <!-- Gallery left -->
      <div>
        <!-- Main image -->
        <div class="surface-panel w-full aspect-[4/5] mb-6 relative overflow-hidden shadow-hard flex items-center justify-center" id="main-img-wrap">
          {product.image ? (
            <img src={product.image} alt={product.name}
              class="w-full h-full object-cover" id="main-img" />
          ) : (
            <span class="text-8xl md:text-9xl">{categoryEmoji[product.category] ?? '📦'}</span>
          )}
          {product.isNew && (
            <span class="absolute top-4 right-4 bg-mint text-dark font-hand text-xs uppercase tracking-[0.16em] px-4 py-1 border border-dark shadow-hard">
              NEW
            </span>
          )}
          {product.bestseller && !product.isNew && (
            <span class="absolute top-4 right-4 bg-pink text-white font-hand text-xs uppercase tracking-[0.16em] px-4 py-1 border border-dark shadow-hard">
              TOP
            </span>
          )}
          {discount && (
            <span class="absolute top-4 left-4 bg-yellow text-dark font-hand text-xs uppercase tracking-[0.16em] px-4 py-1 border border-dark shadow-hard">
              -{discount}%
            </span>
          )}
        </div>
        <!-- Thumbnails -->
        {product.images && product.images.length > 1 && (
          <div class="flex gap-4 overflow-x-auto pb-1">
            {product.images.map((img, i) => (
              <button type="button"
                class="thumb-btn shrink-0 w-20 h-20 md:w-24 md:h-24 cursor-pointer border border-dark shadow-hard hover:-translate-y-1 transition-transform overflow-hidden bg-white p-0"
                data-src={img}
                style={i === 0 ? 'border-color:#FF008C;' : ''}>
                <img src={img} alt={`${product.name} ${i+1}`} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info right -->
      <div class="flex flex-col gap-6 md:gap-8">
        <!-- Collection tag -->
        {product.collection && (
          <span class="tag tag-mint self-start shadow-hard px-4 py-1">
            {product.collection.replace('-', ' ')}
          </span>
        )}

        <!-- Name -->
        <h1 class="font-marker text-4xl md:text-5xl lg:text-6xl text-dark m-0 leading-none glitch-text">
          {product.name}
        </h1>

        <!-- Short desc -->
        <p class="font-hand text-sm md:text-base text-mid m-0 leading-relaxed uppercase tracking-[0.08em]">
          {product.description}
        </p>

        <!-- Price -->
        <div class="flex items-baseline gap-4">
          <span class="font-marker text-4xl md:text-5xl text-mint">
            {product.price.toFixed(2)}€
          </span>
          {product.originalPrice && (
            <span class="font-hand text-base text-mid line-through opacity-70">
              {product.originalPrice.toFixed(2)}€
            </span>
          )}
        </div>

        <!-- Size selector -->
        {product.sizes && (
          <div>
            <p class="ui-label mb-4">talla</p>
            <div class="flex gap-3 flex-wrap" id="size-selector">
              {product.sizes.map((size, idx) => (
                <button
                  class="size-btn font-hand text-sm px-5 py-3 border border-dark cursor-pointer transition-all hover:-translate-y-1 shadow-hard"
                  data-size={size}
                  style={idx === 0 ? 'background:#FF008C; color:#fff;' : 'background:#111111; color:#F5F5F5;'}
                >
                  {size}
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Color selector -->
        {product.colors && (
          <div>
            <p class="ui-label mb-3">color / <span id="color-label" class="text-pink">{product.colors[0]}</span></p>
            <div class="flex gap-4 flex-wrap" id="color-selector">
              {product.colors.map((color, idx) => (
                <button
                  type="button"
                  class="color-btn w-10 h-10 md:w-12 md:h-12 rounded-full border-[3px] cursor-pointer hover:scale-110 transition-all shadow-hard"
                  style={`background:${colorMap[color] ?? '#ccc'}; border-color:${idx === 0 ? '#FF008C' : '#F5F5F5'};`}
                  data-color={color}
                  title={color}
                  aria-label={color}
                ></button>
              ))}
            </div>
          </div>
        )}

        <!-- Add to cart buttons -->
        <div class="flex flex-col gap-4 mt-4">
          <button
            id="add-to-cart-btn"
            data-product-id={product.id}
            data-product-name={product.name}
            data-product-price={product.price}
            data-product-image={product.image ?? ''}
            data-has-sizes={product.sizes && product.sizes.length > 0 ? 'true' : 'false'}
            data-has-colors={product.colors && product.colors.length > 0 ? 'true' : 'false'}
            class="bg-pink text-white border border-dark font-hand text-sm md:text-base uppercase tracking-[0.14em] py-4 md:py-5 cursor-pointer w-full text-center shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all"
          >
            añadir al carrito
          </button>
          <a
            href="/carrito"
            class="bg-dark text-mint border border-dark font-hand text-sm md:text-base uppercase tracking-[0.14em] py-4 md:py-5 cursor-pointer w-full text-center no-underline block shadow-hard hover:-translate-y-1 hover:shadow-hard-lg transition-all"
          >
            comprar ahora
          </a>
        </div>

        <!-- Wishlist + Guarantees -->
        <div class="flex items-center gap-4 flex-wrap">
          <WishlistButton
            client:load
            productId={product.id}
            productName={product.name}
            productSlug={product.slug}
            productImage={product.image}
            productPrice={product.price}
          />
        </div>
        <p class="font-hand text-xs md:text-sm text-mid m-0 uppercase tracking-[0.1em]">
          envio gratis +50 EUR / devolucion 30 dias / visual signal verified
        </p>
      </div>
    </div>
  </div>

  <!-- Description / el chiste -->
  <section class="surface-panel border-x-0 border-y border-dark">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <p class="ui-label mb-4">design notes</p>
      <h2 class="font-marker text-4xl md:text-5xl text-dark mb-8">
        la señal
      </h2>
      <p class="font-hand text-sm md:text-base text-mid leading-relaxed uppercase tracking-[0.08em] mb-10">
        {product.longDescription}
      </p>
      <!-- Feature tags -->
      <div class="flex gap-4 flex-wrap">
        <span class="tag bg-mint-light text-dark border border-dark px-5 py-2 shadow-hard">100% algodon</span>
        <span class="tag bg-mint-light text-dark border border-dark px-5 py-2 shadow-hard">fabricado en espana</span>
        <span class="tag bg-mint-light text-dark border border-dark px-5 py-2 shadow-hard">lavable a 30</span>
        {product.tags.slice(0, 2).map(t => (
          <span class="tag bg-light-pink text-dark border border-dark px-5 py-2 shadow-hard">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 border-t-2 border-dark/10">
    <ProductReviews productId={product.id} client:load />
  </section>

  <!-- Related products -->
  {related.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <h2 class="font-marker text-4xl md:text-5xl text-dark mb-10">
        también te puede gustar
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6 md:gap-10">
        {related.map((p) => (
          <ProductCard product={p} rotation="rotate-0" />
        ))}
      </div>
    </section>
  )}

</Layout>

<script>
  import { addToCart, makeCartKey } from '../../store/cart';

  // Track selected size & color
  let selectedSize: string | undefined = undefined;
  let selectedColor: string | undefined = undefined;

  // Initialize: auto-select first size and first color if available
  const firstSizeBtn = document.querySelector('.size-btn') as HTMLButtonElement | null;
  if (firstSizeBtn) {
    selectedSize = firstSizeBtn.dataset.size ?? undefined;
  }
  const firstColorBtn = document.querySelector('.color-btn') as HTMLButtonElement | null;
  if (firstColorBtn) {
    selectedColor = firstColorBtn.dataset.color ?? undefined;
  }

  // Size selector
  document.querySelectorAll('.size-btn').forEach(b => {
    b.addEventListener('click', () => {
      selectedSize = (b as HTMLButtonElement).dataset.size;
      document.querySelectorAll('.size-btn').forEach(x => {
        (x as HTMLButtonElement).style.background = '#111111';
        (x as HTMLButtonElement).style.color = '#F5F5F5';
      });
      (b as HTMLButtonElement).style.background = '#FF008C';
      (b as HTMLButtonElement).style.color = '#fff';
    });
  });

  // Color selector
  document.querySelectorAll('.color-btn').forEach(b => {
    b.addEventListener('click', () => {
      selectedColor = (b as HTMLButtonElement).dataset.color;
      document.querySelectorAll('.color-btn').forEach(x => {
        (x as HTMLButtonElement).style.borderColor = '#F5F5F5';
      });
      (b as HTMLButtonElement).style.borderColor = '#FF008C';
      // Update label
      const label = document.getElementById('color-label');
      if (label && selectedColor) label.textContent = selectedColor;
    });
  });

  // Add to cart
  const btn = document.getElementById('add-to-cart-btn') as HTMLButtonElement | null;
  btn?.addEventListener('click', () => {
    const hasSizes  = btn.dataset.hasSizes  === 'true';
    const hasColors = btn.dataset.hasColors === 'true';

    // Validate selection
    if (hasSizes && !selectedSize) {
      btn.innerHTML = 'elige una talla';
      btn.style.background = '#FFE600';
      btn.style.color = '#050505';
      setTimeout(() => {
        btn.innerHTML = 'añadir al carrito';
        btn.style.background = '';
        btn.style.color = '';
      }, 2000);
      return;
    }
    if (hasColors && !selectedColor) {
      btn.innerHTML = 'elige un color';
      btn.style.background = '#FFE600';
      btn.style.color = '#050505';
      setTimeout(() => {
        btn.innerHTML = 'añadir al carrito';
        btn.style.background = '';
        btn.style.color = '';
      }, 2000);
      return;
    }

    const size  = hasSizes  ? selectedSize  : undefined;
    const color = hasColors ? selectedColor : undefined;
    const variantId = [size, color].filter(Boolean).join('-') || undefined;

    // Build display name with variant
    const baseName = btn.dataset.productName!;
    const variantParts = [size, color].filter(Boolean);
    const displayName = variantParts.length
      ? `${baseName} — ${variantParts.join(' / ')}`
      : baseName;

    addToCart({
      id:        btn.dataset.productId!,
      name:      displayName,
      price:     parseFloat(btn.dataset.productPrice!),
      image:     btn.dataset.productImage ?? '',
      size,
      color,
      variantId,
    });

    const orig = btn.innerHTML;
    btn.innerHTML = 'signal added';
    setTimeout(() => { btn.innerHTML = orig; }, 1800);
  });

  // Thumbnail gallery
  document.querySelectorAll('.thumb-btn').forEach(b => {
    b.addEventListener('click', () => {
      const src = (b as HTMLButtonElement).dataset.src!;
      const mainImg = document.getElementById('main-img') as HTMLImageElement | null;
      if (mainImg) mainImg.src = src;
      document.querySelectorAll('.thumb-btn').forEach(x => (x as HTMLElement).style.borderColor = '');
      (b as HTMLElement).style.borderColor = '#FF008C';
    });
  });
</script>
