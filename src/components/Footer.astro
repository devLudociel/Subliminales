      <!-- Columna 2: Colecciones -->
      <div>
        <h4 class="font-display font-bold text-xs uppercase tracking-[0.2em] text-ink mb-5">Colecciones</h4>
        <ul class="space-y-3">
          <li><a href="/colecciones" class="font-alt text-sm text-ink-muted hover:text-ink hover:text-neon transition-colors">Mind Control</a></li>
          <li><a href="/colecciones" class="font-alt text-sm text-ink-muted hover:text-ink hover:text-neon transition-colors">Hidden Truth</a></li>
          <li><a href="/colecciones" class="font-alt text-sm text-ink-muted hover:text-ink hover:text-neon transition-colors">Wake Up</a></li>
          <li><a href="/colecciones" class="font-alt text-sm text-ink-muted hover:text-ink hover:text-neon transition-colors">Dual Meaning</a></li>
        </ul>
      </div>

      <!-- Columna 3: Soporte -->
      <div>
        <h4 class="font-display font-bold text-xs uppercase tracking-[0.2em] text-ink mb-5">Soporte</h4>
        <ul class="space-y-3">
          <li><a href="/envios" class="font-alt text-sm text-ink-muted hover:text-ink hover:text-neon transition-colors">Envíos</a></li>
          <li><a href="/devoluciones" class="font-alt text-sm text-ink-muted hover:text-ink hover:text-neon transition-colors">Devoluciones</a></li>
          <li><a href="/contacto" class="font-alt text-sm text-ink-muted hover:text-ink hover:text-neon transition-colors">Contacto</a></li>
          <li><a href="/faq" class="font-alt text-sm text-ink-muted hover:text-ink hover:text-neon transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Columna 4: Newsletter -->
      <div>
        <h4 class="font-display font-bold text-xs uppercase tracking-[0.2em] text-ink mb-5">Newsletter</h4>
        <p class="font-alt text-xs text-ink-muted mb-4 leading-relaxed">
          Nuevos diseños, drops exclusivos y mensajes que no verás en ningún otro sitio.
        </p>
        <form class="space-y-2">
          <input
            type="email"
            placeholder="tu@email.com"
            class="input-field text-sm py-2.5 font-alt"
          />
          <button type="submit" class="w-full btn-primary text-xs py-2.5">
            Suscribirse
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="font-alt text-ink-faint text-xs">© 2025 SUBLIMINAL.ES — Todos los derechos reservados</p>
      <div class="flex gap-6">
        <a href="/privacidad" class="font-alt text-ink-faint hover:text-ink-muted text-xs transition-colors">Privacidad</a>
        <a href="/terminos" class="font-alt text-ink-faint hover:text-ink-muted text-xs transition-colors">Términos</a>
        <a href="/cookies" class="font-alt text-ink-faint hover:text-ink-muted text-xs transition-colors">Cookies</a>
      </div>
    </div>
