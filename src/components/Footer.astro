<footer class="border-t border-dark mt-auto bg-bg">
  <!-- Main dark section -->
  <div class="surface-panel border-x-0 border-b-0 px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-12 md:gap-8">
      
      <!-- Col 1: Brand -->
      <div class="text-center sm:text-left">
        <a href="/" class="font-marker text-3xl md:text-4xl text-dark glitch-text no-underline inline-block mb-4 hover:text-pink transition-colors">
          subliminal.es
        </a>
        <p class="font-hand text-sm md:text-base text-mid m-0 leading-relaxed max-w-xs mx-auto sm:mx-0 uppercase tracking-[0.12em]">
          visual mind lab<br/>
          diseno. ruido. glitch. streetwear.
        </p>
        <div class="barcode mt-6 max-w-[260px] mx-auto sm:mx-0"></div>
      </div>

      <!-- Col 2: Tienda -->
      <div class="text-center sm:text-left">
        <p class="ui-label mb-6">
          tienda
        </p>
        <ul class="list-none p-0 m-0 flex flex-col gap-3">
          <li><a href="/tienda?cat=camisetas" class="font-hand text-sm text-dark/70 hover:text-pink no-underline transition-colors uppercase tracking-[0.12em]">camisetas</a></li>
          <li><a href="/tienda?cat=posters"   class="font-hand text-sm text-dark/70 hover:text-mint no-underline transition-colors uppercase tracking-[0.12em]">posters</a></li>
          <li><a href="/colecciones"          class="font-hand text-sm text-dark/70 hover:text-pink no-underline transition-colors uppercase tracking-[0.12em]">colecciones</a></li>
          <li><a href="/tienda"               class="font-hand text-sm text-dark/70 hover:text-mint no-underline transition-colors uppercase tracking-[0.12em]">ver todo</a></li>
        </ul>
      </div>

      <!-- Col 3: Ayuda -->
      <div class="text-center sm:text-left">
        <p class="ui-label mb-6">
          ayuda
        </p>
        <ul class="list-none p-0 m-0 flex flex-col gap-3">
          <li><a href="/politicas"        class="font-hand text-sm text-dark/70 hover:text-pink no-underline transition-colors uppercase tracking-[0.12em]">envios y devoluciones</a></li>
          <li><a href="/sobre-nosotros"   class="font-hand text-sm text-dark/70 hover:text-mint no-underline transition-colors uppercase tracking-[0.12em]">sobre nosotros</a></li>
          <li><a href="/contacto"         class="font-hand text-sm text-dark/70 hover:text-pink no-underline transition-colors uppercase tracking-[0.12em]">contacto</a></li>
          <li><a href="/faq"              class="font-hand text-sm text-dark/70 hover:text-mint no-underline transition-colors uppercase tracking-[0.12em]">faq</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom strip -->
  <div class="bg-pink border-t border-dark px-4 sm:px-6 lg:px-8 py-4">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4 text-center sm:text-left">
      <span class="font-hand text-xs md:text-sm text-white uppercase tracking-[0.18em]">© 2025 subliminal.es / visual signal on</span>
      <div class="flex gap-6 flex-wrap justify-center">
        <a href="/politicas" class="font-hand text-xs md:text-sm text-white/80 hover:text-white no-underline transition-colors uppercase tracking-[0.16em]">privacidad</a>
        <a href="/politicas" class="font-hand text-xs md:text-sm text-white/80 hover:text-white no-underline transition-colors uppercase tracking-[0.16em]">terminos</a>
        <a href="/politicas" class="font-hand text-xs md:text-sm text-white/80 hover:text-white no-underline transition-colors uppercase tracking-[0.16em]">cookies</a>
      </div>
    </div>
  </div>
</footer>
