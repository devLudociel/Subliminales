<footer class="bg-bg-secondary border-t border-white/5 mt-0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Columna 1: Marca -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4">
          <span class="font-display font-black text-lg tracking-[0.12em] text-ink">SUBLIMINAL</span>
          <span class="font-display font-black text-lg tracking-[0.12em] text-brand">.</span>
          <span class="font-display font-black text-lg tracking-[0.12em] text-ink-muted">ES</span>
