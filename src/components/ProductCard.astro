---
import type { Product } from '../data/products';

interface Props {
  product: Product;
  rotation?: string;
}

const { product, rotation = 'rotate(-1deg)' } = Astro.props;

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;

const categoryEmoji: Record<string, string> = {
  camisetas:  '👕',
  sudaderas:  '🧥',
  tazas:      '☕',
  termos:     '🧃',
  posters:    '🖼️',
  accesorios: '🎁',
};

const btnColors: Record<string, { bg: string; text: string }> = {
  camisetas:  { bg: 'bg-pink',  text: 'text-white' },
  sudaderas:  { bg: 'bg-mint',  text: 'text-dark' },
  tazas:      { bg: 'bg-light-pink', text: 'text-dark' },
  termos:     { bg: 'bg-dark',  text: 'text-mint' },
  posters:    { bg: 'bg-pink',  text: 'text-white' },
  accesorios: { bg: 'bg-mint',  text: 'text-dark' },
};

const btn = btnColors[product.category] ?? { bg: 'bg-pink', text: 'text-white' };
---

<div class="border-2 border-dark bg-white p-4 md:p-5 flex flex-col transition-transform duration-200 hover:scale-[1.03] shadow-hard rounded-xl">
  <!-- Image area -->
  <a href={`/producto/${product.slug}`} class="block no-underline">
    <div class="img-placeholder w-full aspect-[3/4] mb-4 relative overflow-hidden rounded-lg bg-bg">
      <span class="text-5xl md:text-6xl">{categoryEmoji[product.category] ?? '📦'}</span>
      {product.isNew && (
        <span class="absolute top-3 right-3 bg-mint text-dark font-hand text-base px-3 py-1 border-2 border-dark rotate-2 shadow-hard">
          NEW
        </span>
      )}
      {product.bestseller && !product.isNew && (
        <span class="absolute top-3 right-3 bg-pink text-white font-hand text-base px-3 py-1 border-2 border-dark rotate-2 shadow-hard">
          TOP
        </span>
      )}
      {discount && (
        <span class="absolute top-3 left-3 bg-pink text-white font-hand text-base px-3 py-1 border-2 border-dark shadow-hard">
          -{discount}%
        </span>
      )}
    </div>
  </a>

  <span class="font-hand text-lg text-mint uppercase tracking-widest mb-1 font-bold">
    {product.category}
  </span>
  <a href={`/producto/${product.slug}`} class="no-underline">
    <p class="font-hand text-xl md:text-2xl font-bold text-dark m-0 mb-2 leading-tight hover:text-pink transition-colors">
      {product.name}
    </p>
  </a>
  <p class="font-hand text-xl md:text-2xl text-mid m-0 mb-4">
    {product.price.toFixed(2)}€
    {product.originalPrice && (
      <span class="line-through ml-2 opacity-60">{product.originalPrice.toFixed(2)}€</span>
    )}
  </p>

  <button
    class={`add-to-cart ${btn.bg} ${btn.text} border-2 border-dark font-hand text-xl md:text-2xl py-3 px-4 cursor-pointer w-full text-center shadow-hard hover:-translate-y-1 transition-all mt-auto rounded-lg`}
    data-product-id={product.id}
    data-product-name={product.name}
    data-product-price={product.price}
  >
    🛒 añadir
  </button>
</div>

<script>
  import { addToCart } from '../store/cart';

  document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLButtonElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        image: '',
      });
      const orig = el.innerHTML;
      el.innerHTML = '✓ añadido';
      setTimeout(() => { el.innerHTML = orig; }, 1500);
    });
  });
</script>
