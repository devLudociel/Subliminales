---
import type { Product } from '../data/products';

interface Props {
  product: Product;
  rotation?: string;
}

const { product, rotation = 'rotate(-1deg)' } = Astro.props;

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;

const categoryEmoji: Record<string, string> = {
  camisetas:  '👕',
  sudaderas:  '🧥',
  tazas:      '☕',
  termos:     '🧃',
  posters:    '🖼️',
  accesorios: '🎁',
};

const btnColors: Record<string, { bg: string; text: string }> = {
  camisetas:  { bg: 'bg-pink',  text: 'text-white' },
  sudaderas:  { bg: 'bg-mint',  text: 'text-dark' },
  tazas:      { bg: 'bg-violet', text: 'text-white' },
  termos:     { bg: 'bg-dark',  text: 'text-mint' },
  posters:    { bg: 'bg-mint',  text: 'text-dark' },
  accesorios: { bg: 'bg-yellow', text: 'text-dark' },
};

const btn = btnColors[product.category] ?? { bg: 'bg-pink', text: 'text-white' };
---

<div class="surface-panel p-3 md:p-4 flex flex-col transition-transform duration-200 hover:-translate-y-1 shadow-hard">
  <!-- Image area -->
  <a href={`/producto/${product.slug}`} class="block no-underline">
    <div class="w-full aspect-[3/4] mb-4 relative overflow-hidden bg-bg flex items-center justify-center border border-dark">
      {product.image
        ? <img src={product.image} alt={product.name} class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
        : <span class="text-5xl md:text-6xl">{categoryEmoji[product.category] ?? '📦'}</span>
      }
      {product.isNew && (
        <span class="absolute top-3 right-3 bg-mint text-dark font-hand text-[10px] uppercase tracking-[0.16em] px-3 py-1 border border-dark shadow-hard">
          NEW
        </span>
      )}
      {product.bestseller && !product.isNew && (
        <span class="absolute top-3 right-3 bg-pink text-white font-hand text-[10px] uppercase tracking-[0.16em] px-3 py-1 border border-dark shadow-hard">
          TOP
        </span>
      )}
      {discount && (
        <span class="absolute top-3 left-3 bg-yellow text-dark font-hand text-[10px] uppercase tracking-[0.16em] px-3 py-1 border border-dark shadow-hard">
          -{discount}%
        </span>
      )}
    </div>
  </a>

  <span class="font-hand text-[11px] text-mint uppercase tracking-[0.18em] mb-2 font-bold">
    {product.collection ?? product.category}
  </span>
  <a href={`/producto/${product.slug}`} class="no-underline">
    <p class="font-marker text-lg md:text-xl font-bold text-dark m-0 mb-2 leading-tight hover:text-pink transition-colors">
      {product.name}
    </p>
  </a>
  <p class="font-hand text-sm md:text-base text-mid m-0 mb-3">
    {product.price.toFixed(2)}€
    {product.originalPrice && (
      <span class="line-through ml-2 opacity-60">{product.originalPrice.toFixed(2)}€</span>
    )}
  </p>
  <div class="barcode mb-3 h-4"></div>

  <button
    class={`add-to-cart ${btn.bg} ${btn.text} border border-dark font-hand text-xs uppercase tracking-[0.14em] py-3 px-4 cursor-pointer w-full text-center shadow-hard hover:-translate-y-1 transition-all mt-auto`}
    data-product-id={product.id}
    data-product-name={product.name}
    data-product-price={product.price}
  >
    añadir / cart
  </button>
</div>

<script>
  import { addToCart } from '../store/cart';

  document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLButtonElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        image: '',
      });
      const orig = el.innerHTML;
      el.innerHTML = 'signal added';
      setTimeout(() => { el.innerHTML = orig; }, 1500);
    });
  });
</script>
