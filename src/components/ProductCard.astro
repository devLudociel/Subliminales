---
import type { Product } from '../data/products';

interface Props {
  product: Product;
  rotation?: string;
}

const { product, rotation = 'rotate(-1deg)' } = Astro.props;

const discount = product.originalPrice
  ? Math.round((1 - product.price / product.originalPrice) * 100)
  : null;

const categoryEmoji: Record<string, string> = {
  camisetas:  '👕',
  sudaderas:  '🧥',
  tazas:      '☕',
  termos:     '🧃',
  posters:    '🖼️',
  accesorios: '🎁',
};

const btnColors: Record<string, { bg: string; color: string }> = {
  camisetas:  { bg: '#f72585', color: '#fff' },
  sudaderas:  { bg: '#4cc9a0', color: '#111' },
  tazas:      { bg: '#fde8f0', color: '#111' },
  termos:     { bg: '#111',    color: '#4cc9a0' },
  posters:    { bg: '#f72585', color: '#fff' },
  accesorios: { bg: '#4cc9a0', color: '#111' },
};

const btn = btnColors[product.category] ?? { bg: '#f72585', color: '#fff' };
---

<div
  style={`transform:${rotation}; border:1.5px solid #111; background:#fff; padding:8px; display:flex; flex-direction:column; transition:transform 0.2s;`}
  class="hover:scale-[1.02]"
>
  <!-- Image area -->
  <a href={`/producto/${product.slug}`} style="display:block; text-decoration:none;">
    <div class="img-placeholder" style="width:100%; aspect-ratio:3/4; margin-bottom:8px; position:relative; overflow:hidden;">
      <span style="font-size:32px;">{categoryEmoji[product.category] ?? '📦'}</span>
      {product.isNew && (
        <span style="position:absolute; top:6px; right:6px; background:#4cc9a0; color:#111; font-family:'Caveat',cursive; font-size:10px; padding:2px 6px; border:1.5px solid #111; transform:rotate(1.5deg);">
          NEW
        </span>
      )}
      {product.bestseller && !product.isNew && (
        <span style="position:absolute; top:6px; right:6px; background:#f72585; color:#fff; font-family:'Caveat',cursive; font-size:10px; padding:2px 6px; border:1.5px solid #111; transform:rotate(1.5deg);">
          TOP
        </span>
      )}
      {discount && (
        <span style="position:absolute; top:6px; left:6px; background:#f72585; color:#fff; font-family:'Caveat',cursive; font-size:10px; padding:2px 6px; border:1.5px solid #111;">
          -{discount}%
        </span>
      )}
    </div>
  </a>

  <span style="font-family:'Caveat',cursive; font-size:10px; color:#4cc9a0; text-transform:uppercase; letter-spacing:1px; margin-bottom:2px;">
    {product.category}
  </span>
  <a href={`/producto/${product.slug}`} style="text-decoration:none;">
    <p style="font-family:'Caveat',cursive; font-size:13px; font-weight:700; color:#111; margin:0 0 4px; line-height:1.2;">
      {product.name}
    </p>
  </a>
  <p style="font-family:'Caveat',cursive; font-size:12px; color:#666; margin:0 0 8px;">
    {product.price.toFixed(2)}€
    {product.originalPrice && (
      <span style="text-decoration:line-through; margin-left:4px; opacity:0.6;">{product.originalPrice.toFixed(2)}€</span>
    )}
  </p>

  <button
    class="add-to-cart"
    data-product-id={product.id}
    data-product-name={product.name}
    data-product-price={product.price}
    style={`background:${btn.bg}; color:${btn.color}; border:1.5px solid #111; font-family:'Caveat',cursive; font-size:12px; padding:5px 10px; cursor:pointer; width:100%; text-align:center;`}
  >
    🛒 añadir
  </button>
</div>

<script>
  import { addToCart } from '../store/cart';

  document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLButtonElement;
      addToCart({
        id: el.dataset.productId!,
        name: el.dataset.productName!,
        price: parseFloat(el.dataset.productPrice!),
        image: '',
      });
      const orig = el.innerHTML;
      el.innerHTML = '✓ añadido';
      setTimeout(() => { el.innerHTML = orig; }, 1500);
    });
  });
</script>
