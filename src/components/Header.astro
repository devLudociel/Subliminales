---
import CartIcon from './CartIcon';
import UserMenu from './UserMenu';
---

<header class="sticky top-0 z-50 flex flex-col border-b border-dark bg-bg/95 backdrop-blur overflow-visible">
  <!-- Signal strip -->
  <div class="hidden md:block border-b border-dark/40 bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-1.5 flex items-center justify-between gap-6 font-hand text-[11px] uppercase tracking-[0.18em] text-mid">
      <span class="text-mint">visual mind lab</span>
      <span class="hidden lg:inline">diseno grafico / sublimacion / dtf / streetwear</span>
      <span class="text-pink">signal detected</span>
    </div>
  </div>

  <!-- Main navigation -->
  <div class="surface-panel header-panel relative z-30 border-x-0 border-t-0 px-4 py-3 md:py-4 flex justify-between items-center overflow-visible">

    <!-- Logo -->
    <a href="/" class="group no-underline shrink-0 inline-flex items-center gap-3">
      <span class="w-10 h-10 border border-dark flex items-center justify-center relative overflow-hidden bg-bg">
        <span class="font-marker text-2xl text-dark glitch-text leading-none">S</span>
      </span>
      <span class="leading-none">
        <span class="font-marker text-xl md:text-3xl text-dark glitch-text block tracking-normal">subliminal.es</span>
        <span class="hidden sm:block font-hand text-[10px] md:text-xs text-mid uppercase tracking-[0.28em] mt-1">visual mind lab</span>
      </span>
    </a>

    <!-- Nav (desktop) -->
    <nav class="hidden md:flex gap-4 lg:gap-6 items-center">
      <a href="/tienda?cat=camisetas" class="font-hand text-sm lg:text-base text-dark/80 hover:text-pink no-underline transition-colors uppercase tracking-[0.12em]">camisetas</a>
      <a href="/tienda?cat=posters" class="font-hand text-sm lg:text-base text-dark/80 hover:text-mint no-underline transition-colors uppercase tracking-[0.12em]">posters</a>
      <a href="/colecciones" class="font-hand text-sm lg:text-base text-dark/80 hover:text-pink no-underline transition-colors uppercase tracking-[0.12em]">colecciones</a>
      <a href="/como-funciona" class="font-hand text-sm lg:text-base text-dark/80 hover:text-mint no-underline transition-colors uppercase tracking-[0.12em]">lab</a>
      <a href="/blog" class="font-hand text-sm lg:text-base text-dark/80 hover:text-pink no-underline transition-colors uppercase tracking-[0.12em]">blog</a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-3 md:gap-5">
      <a href="/buscar" class="font-hand text-xs md:text-sm text-mid hover:text-mint transition-colors no-underline hidden sm:block uppercase tracking-[0.16em]">buscar</a>

      <!-- User menu (React, handles auth state) -->
      <UserMenu client:load />

      <CartIcon client:load />

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden bg-transparent border border-dark text-dark cursor-pointer p-1.5 hover:text-pink transition-colors"
        aria-label="Menú"
      >
        <svg id="menu-icon" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"/>
        </svg>
        <svg id="close-icon" class="hidden" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Level 2: mint ticker -->
  <div class="relative z-10 bg-pink border-b border-dark py-2 overflow-hidden">
    <div class="ticker-track flex whitespace-nowrap">
      <span class="font-hand text-xs md:text-sm text-white tracking-[0.22em] px-4 font-semibold uppercase">visual signal detected · ideas que se quedan pegadas · nuevos drops · envíos a toda españa · </span>
      <span class="font-hand text-xs md:text-sm text-white tracking-[0.22em] px-4 font-semibold uppercase">visual signal detected · ideas que se quedan pegadas · nuevos drops · envíos a toda españa · </span>
      <span class="font-hand text-xs md:text-sm text-white tracking-[0.22em] px-4 font-semibold uppercase">visual signal detected · ideas que se quedan pegadas · nuevos drops · envíos a toda españa · </span>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-bg border-b border-dark px-6 py-6 flex flex-col gap-4 shadow-xl">
    <a href="/tienda?cat=camisetas" class="font-hand text-lg text-dark/95 no-underline py-3 border-b border-dark/20 uppercase tracking-[0.14em]">camisetas</a>
    <a href="/tienda?cat=posters"   class="font-hand text-lg text-dark/95 no-underline py-3 border-b border-dark/20 uppercase tracking-[0.14em]">posters</a>
    <a href="/colecciones"          class="font-hand text-lg text-dark/95 no-underline py-3 border-b border-dark/20 uppercase tracking-[0.14em]">colecciones</a>
    <a href="/como-funciona"        class="font-hand text-lg text-dark/95 no-underline py-3 border-b border-dark/20 uppercase tracking-[0.14em]">visual lab</a>
    <a href="/blog"                 class="font-hand text-lg text-dark/95 no-underline py-3 border-b border-dark/20 uppercase tracking-[0.14em]">blog</a>
    <a href="/perfil"               class="font-hand text-lg text-mint no-underline py-3 mt-2 flex items-center gap-3 uppercase tracking-[0.14em]">
      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
      </svg>
      cuenta
    </a>
  </div>
</header>

<script>
  const btn     = document.getElementById('mobile-menu-btn');
  const menu    = document.getElementById('mobile-menu');
  const menuIc  = document.getElementById('menu-icon');
  const closeIc = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const open = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    menuIc?.classList.toggle('hidden', !open);
    closeIc?.classList.toggle('hidden', open);
  });
</script>
