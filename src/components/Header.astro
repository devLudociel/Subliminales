---
import CartIcon from './CartIcon';
---

<header class="sticky top-0 z-50">
  <!-- Level 1: pink bar -->
  <div style="background:#f72585; border-bottom:2px solid #111; padding:9px 20px; display:flex; justify-content:space-between; align-items:center;">

    <!-- Logo -->
    <a href="/" style="font-family:'Permanent Marker',cursive; font-size:18px; color:#fff; text-decoration:none; flex-shrink:0;">
      SUBLIMINAL.ES
    </a>

    <!-- Nav (desktop) -->
    <nav class="hidden md:flex" style="gap:20px; align-items:center;">
      <a href="/tienda?cat=camisetas" style="font-family:'Caveat',cursive; font-size:14px; color:rgba(255,255,255,0.88); text-decoration:none;">camisetas</a>
      <span style="color:rgba(255,255,255,0.4);">·</span>
      <a href="/tienda?cat=sudaderas" style="font-family:'Caveat',cursive; font-size:14px; color:rgba(255,255,255,0.88); text-decoration:none;">sudaderas</a>
      <span style="color:rgba(255,255,255,0.4);">·</span>
      <a href="/tienda?cat=tazas" style="font-family:'Caveat',cursive; font-size:14px; color:rgba(255,255,255,0.88); text-decoration:none;">tazas</a>
      <span style="color:rgba(255,255,255,0.4);">·</span>
      <a href="/colecciones" style="font-family:'Caveat',cursive; font-size:14px; color:rgba(255,255,255,0.88); text-decoration:none;">colecciones</a>
    </nav>

    <!-- Actions -->
    <div style="display:flex; align-items:center; gap:12px;">
      <span style="font-family:'Caveat',cursive; font-size:14px; color:rgba(255,255,255,0.88); cursor:pointer;">buscar</span>
      <CartIcon client:load />

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden"
        style="background:none; border:none; color:#fff; cursor:pointer; padding:4px;"
        aria-label="Menú"
      >
        <svg id="menu-icon" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"/>
        </svg>
        <svg id="close-icon" class="hidden" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Level 2: mint ticker -->
  <div style="background:#4cc9a0; border-bottom:1.5px solid #111; padding:5px 0; overflow:hidden;">
    <div class="ticker-track">
      <span style="font-family:'Caveat',cursive; font-size:12px; color:#111; letter-spacing:0.5px; padding:0 20px;">ENVÍOS A TODA ESPAÑA · NUEVOS DROPS CADA MES · ROPA CON CHISTE DESDE 2025 · DEVOLUCIÓN GRATIS 30 DÍAS · </span>
      <span style="font-family:'Caveat',cursive; font-size:12px; color:#111; letter-spacing:0.5px; padding:0 20px;">ENVÍOS A TODA ESPAÑA · NUEVOS DROPS CADA MES · ROPA CON CHISTE DESDE 2025 · DEVOLUCIÓN GRATIS 30 DÍAS · </span>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden" style="background:#f72585; border-bottom:2px solid #111; padding:12px 20px; display:flex; flex-direction:column; gap:8px;">
    <a href="/tienda?cat=camisetas" style="font-family:'Caveat',cursive; font-size:16px; color:rgba(255,255,255,0.9); text-decoration:none; padding:4px 0; border-bottom:1px solid rgba(255,255,255,0.2);">camisetas</a>
    <a href="/tienda?cat=sudaderas" style="font-family:'Caveat',cursive; font-size:16px; color:rgba(255,255,255,0.9); text-decoration:none; padding:4px 0; border-bottom:1px solid rgba(255,255,255,0.2);">sudaderas</a>
    <a href="/tienda?cat=tazas"     style="font-family:'Caveat',cursive; font-size:16px; color:rgba(255,255,255,0.9); text-decoration:none; padding:4px 0; border-bottom:1px solid rgba(255,255,255,0.2);">tazas</a>
    <a href="/colecciones"          style="font-family:'Caveat',cursive; font-size:16px; color:rgba(255,255,255,0.9); text-decoration:none; padding:4px 0;">colecciones</a>
  </div>
</header>

<script>
  const btn    = document.getElementById('mobile-menu-btn');
  const menu   = document.getElementById('mobile-menu');
  const menuIc = document.getElementById('menu-icon');
  const closeIc = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const open = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    menuIc?.classList.toggle('hidden', !open);
    closeIc?.classList.toggle('hidden', open);
  });
</script>
