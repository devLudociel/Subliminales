---
import CartIcon from './CartIcon';
---

<header class="sticky top-0 z-50 bg-dark/80 backdrop-blur-xl border-b border-dark-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary-500 to-accent flex items-center justify-center shadow-lg group-hover:shadow-accent/50 transition-shadow duration-300">
          <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        </div>
        <span class="font-display font-bold text-xl text-gradient">Subliminal.es</span>
      </a>

      <!-- Nav -->
      <nav class="hidden md:flex items-center gap-1">
        <a href="/" class="btn-ghost text-sm">Inicio</a>
        <a href="/tienda" class="btn-ghost text-sm">Tienda</a>
        <a href="/como-funciona" class="btn-ghost text-sm">Cómo Funciona</a>
        <a href="/blog" class="btn-ghost text-sm">Blog</a>
        <a href="/contacto" class="btn-ghost text-sm">Contacto</a>
      </nav>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <CartIcon client:load />
        <a href="/tienda" class="hidden sm:flex btn-primary text-sm py-2 px-4">
          Comprar
        </a>

        <!-- Mobile menu btn -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-400 hover:text-white hover:bg-white/5 transition-colors"
          aria-label="Menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-dark-border bg-dark">
    <div class="px-4 py-3 space-y-1">
      <a href="/" class="block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors text-sm font-medium">Inicio</a>
      <a href="/tienda" class="block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors text-sm font-medium">Tienda</a>
      <a href="/como-funciona" class="block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors text-sm font-medium">Cómo Funciona</a>
      <a href="/blog" class="block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors text-sm font-medium">Blog</a>
      <a href="/contacto" class="block px-3 py-2 rounded-lg text-gray-300 hover:text-white hover:bg-white/5 transition-colors text-sm font-medium">Contacto</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
